<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#Raftaara - Fashion Store</title>
    <link rel="stylesheet" href="/css/output.css">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- SweetAlert2 JS -->
    <link rel="preload" href="/BLOVERLY.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/ClashDisplay-Regular.woff" as="font" type="font/woff" crossorigin>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap');
        
      
        :root {
            --cream:#faf9f7;
            --card-bg:#f3f1ee;
            --accent:#c8102e;
            --accent-light:#f5e0e4;
            --accent-mid:#e8a0ad;
            --text-primary:#1a1a1a;
            --text-muted:#7a7a7a;
            --text-light:#a8a8a8;
            --shadow-sm:0 2px 12px rgba(0,0,0,.06);
            --shadow-md:0 6px 24px rgba(0,0,0,.1);
            --radius:18px;
        }
        .serif-font {
            font-family: 'Playfair Display', serif;
        }
       
        .font-bloverly {
          font-family: "bloverly", system-ui, sans-serif;
        }
        .font-clash {
          font-family: "Clash-display", system-ui, sans-serif;
        }

        .hero {
            position:relative;
            background:#1a1a1a;
            color:#fff;
            padding:56px 24px 52px;
            text-align:center;
            overflow:hidden;
        }
        .hero::before {
            content:'';
            position:absolute;
            inset:0;
            background:
            radial-gradient(ellipse 70% 60% at 20% 50%, rgba(200,16,46,.18) 0%, transparent 70%),
            radial-gradient(ellipse 50% 80% at 80% 40%, rgba(200,16,46,.12) 0%, transparent 70%);
            pointer-events:none;
        }
        .hero-badge {
            display:inline-block;
            background:var(--accent);
            color:#fff;
            font-size:.72rem;
            font-weight:600;
            letter-spacing:.18em;
            text-transform:uppercase;
            padding:6px 18px;
            border-radius:50px;
            margin-bottom:18px;
            position:relative;
            animation:pulse-badge 2.4s ease-in-out infinite;
        }
        @keyframes pulse-badge {
            0%,100%{ box-shadow:0 0 0 0 rgba(200,16,46,.45); }
            50%   { box-shadow:0 0 0 8px rgba(200,16,46,0); }
        }
        .hero h1 {
            font-family:'Playfair Display',serif;
            font-weight:300;
            font-size:clamp(2.4rem,6vw,3.8rem);
            letter-spacing:-.02em;
            line-height:1.1;
            position:relative;
        }
        .hero h1 em {
            font-style:italic;
            color:var(--accent-mid);
        }
        .hero-sub {
            margin-top:14px;
            color:#9a9a9a;
            font-size:.88rem;
            font-weight:400;
            position:relative;
        }

        .countdown-strip {
            background:var(--accent);
            color:#fff;
            text-align:center;
            padding:10px 16px;
            font-size:.78rem;
            font-weight:500;
            letter-spacing:.06em;
            display:flex;
            align-items:center;
            justify-content:center;
            gap:10px;
        }
        .countdown-strip .timer {
            font-family:'Playfair Display',serif;
            font-size:.95rem;
            font-weight:600;
            letter-spacing:.04em;
        }
        .badge-discount {
            position:absolute;
            top:14px;
            left:14px;
            background:var(--accent);
            color:#fff;
            font-size:.72rem;
            font-weight:600;
            padding:5px 11px;
            border-radius:50px;
            z-index:2;
            letter-spacing:.02em;
        }
        .price-save {
            font-size:.72rem;
            color:var(--accent);
            font-weight:600;
            background:var(--accent-light);
            padding:2px 8px;
            border-radius:50px;
        }

        /* ── RESPONSIVE ADDITIONS ONLY ── */

        /* Hero banner image height */
        .hero-banner {
            height: 510px;
        }
        @media (max-width: 768px) {
            .hero-banner {
                height: 260px;
            }
        }

        /* Product card image height */
        .product-img-wrap {
            height: 350px;
        }
        @media (max-width: 480px) {
            .product-img-wrap {
                height: 260px;
            }
        }

        /* CTA section */
        .cta-section-wrap {
            height: 800px;
        }
        @media (max-width: 768px) {
            .cta-section-wrap {
                height: auto;
                min-height: 420px;
            }
            .cta-section-wrap img {
                position: relative !important;
                height: 420px;
                object-position: center top;
            }
            .cta-overlay {
                padding: 24px 20px !important;
            }
            .cta-heading {
                font-size: 36px !important;
                line-height: 1.15 !important;
            }
            .cta-sub {
                font-size: 14px !important;
            }
            .cta-btn {
                font-size: 18px !important;
                padding: 10px 24px !important;
            }
        }
        @media (max-width: 480px) {
            .cta-heading {
                font-size: 26px !important;
            }
        }

        /* Footer brand heading */
        .footer-brand {
            font-size: clamp(48px, 14vw, 125px);
        }

        /* Marquee font size */
        .marquee-track {
            font-size: clamp(28px, 8vw, 60px);
        }

        /* Hero section padding */
        @media (max-width: 768px) {
            .hero {
                padding: 36px 16px 32px;
            }
        }
        .animate-fade-in {
      animation: fadeIn 0.4s ease-out;
    }
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    @keyframes fadeIn {
      0% { opacity: 0; transform: translateY(-10px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .loading-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
      z-index: 9999;
      justify-content: center;
      align-items: center;
    }
    .loading-overlay.active {
      display: flex;
    }
    .spinner {
      border: 4px solid rgba(255, 255, 255, 0.2);
      border-top: 4px solid #ef4444;
      border-radius: 50%;
      width: 60px;
      height: 60px;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    </style>
</head>
<body class="bg-white">
    <div id="loadingOverlay" class="loading-overlay">
    <div class="text-center">
      <div class="spinner mx-auto mb-4"></div>
      <p class="text-white text-xl font-semibold">Uploading product...</p>
      <p class="text-gray-300 text-sm mt-2">Please wait while we process your request</p>
    </div>
  </div>

    <!-- Header/Navigation -->
     <% if (error) { %>
        <script>
          Swal.fire({
                toast: true,
                icon: 'error',
                title: '<%=error%>',
                position: 'top-right',
                showConfirmButton: false,
                timer: 3000
            });
        </script>
      <% } %>
     
     <%- include('../Partials/nav-bar') %>

    <!-- Mobile Menu Button -->
    <!-- <button id="mobileMenuButton" class="md:hidden border border-black px-4 py-1 rounded text-sm font-clash">
      Menu
    </button> -->

    <!-- Login/Sign-up Button (Hidden on mobile until we toggle menu) -->
    
  </header>

  <!-- Mobile Menu (initially hidden) -->
  <div id="mobileMenu" class="hidden md:hidden px-6 pb-4 space-y-4 font-clash">
    
    
    <div class="flex items-center gap-4">
            <button class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center hover:bg-gray-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </button>
            <button class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center hover:bg-gray-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
            </button>
            <a href="/profile/wishlist">
                <button class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center hover:bg-gray-300">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
                    </svg>
                </button>
            </a>
            <a href="/profile">
                <button class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center hover:bg-gray-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </button>
            </a>
            
        </div>
    
  </div>

    <!-- Hero Section -->
    <section class="container mx-auto px-4 ">
        <div class="hero-banner bg-gray-100 rounded-3xl overflow-hidden relative">
            <img src="/banner.png" 
                 alt="Hero" 
                 class="w-full h-full object-cover">
            <div class="absolute bottom-8 left-0 right-0 flex justify-center space-x-2">
                <button class="w-2 h-2 rounded-full bg-gray-400"></button>
                
            </div>
        </div>
    </section>

    <!-- Popular Right Now Section -->
   <section class="container mx-auto px-4 py-12">
        <h2 class="text-4xl serif-font font-light mb-8 font-bloverly">Popular Right Now</h2>
        
       

        <!-- Product Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 font-clash">
            <!-- Product Cards -->
            <% product.forEach(product=>{ %>
                <% const save = product.basePrice - product.price %>
                <% const isWishlist = wishlist.some(e => e.variantId._id.toString() === product._id.toString() ) %>
                <div class="product-card">
                    <div class="product-img-wrap bg-gray-100 rounded-2xl overflow-hidden mb-3 relative">
                        <a href="/home/product-details/<%= product.productId._id %>?size=<%= product.size %>&color=<%= product.color %>">
                            <img src="<%= product.image[0] %>" 
                                alt="<%= product.products[0].name %>" 
                                loading="lazy"
                                class="w-full h-full object-cover <%= product.stock <= 0 ? 'opacity-50' : '' %>">
                            <% if (product.stock <= 0) { %>
                                <div class="absolute inset-0 flex items-center justify-center bg-opacity-40">
                                    <span class="bg-white text-black px-6 py-2 rounded-full font-semibold text-sm">
                                        Out of Stock
                                    </span>
                                </div>
                            <% } %>
                        </a>

                        <!-- Wishlist Button (Top Right) — now outside <a>, still inside the relative container -->
                        <% if(product.stock>0) {%>
                            <button 
                                data-variant="<%= product._id %>"
                                
                                class="heartBtn absolute top-3 right-3 bg-white rounded-full p-2 shadow-md hover:bg-gray-50 transition-colors z-10"
                                <%= product.stock <= 0 ? 'disabled' : '' %>
                                aria-label="Add to wishlist">
                                <i class="change <%= isWishlist==true ? 'fa-solid fa-heart':'fa-regular fa-heart'  %>   transition-transform duration-200 "></i>
                            </button>
                        <% } %>
                    </div>
                    
                    <div class="flex justify-between items-start mb-3">
                        <div>
                            <h3 class="font-medium text-sm mb-1"><%= product.products[0].name %></h3>
                            <p class="text-lg font-semibold">₹<%= product.price %></p>
                            <% if(save <= 0) { %>
                                
                            <% } else { %>
                                <span class="price-save">Save ₹<%= save.toFixed(2) %></span>
                                
                            <% } %>
                            <% if (product.stock <= 0) { %>
                                <p class="text-red-600 text-xs mt-1">Currently Unavailable</p>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Add to Cart Button -->
                    <button 
                        id="addToCartBtn"
                        onclick="addToCart('<%= product._id %>')"
                        class="w-full py-2.5 px-4 rounded-lg font-medium text-sm transition-all <%= product.stock <= 0 ? 'bg-gray-300 text-gray-500 cursor-not-allowed' : 'bg-black text-white hover:bg-gray-800' %>"
                        <%= product.stock <= 0 ? 'disabled' : '' %>>
                        <%= product.stock <= 0 ? 'Out of Stock' : 'Add to Cart' %>
                    </button>
                </div>
            <% }) %>
        </div>

        <div class="flex justify-end">
            <a  class="mr-10" href="/products">Shop more →</a>
        </div>
        
    </section>


    <!-- <div class="countdown-strip">
    ⏳ &nbsp; Offers end in &nbsp; <span class="timer" id="countdown">02:14:38</span> &nbsp; — Don't miss out!
    </div> -->
    <header class="hero">
        <div class="hero-badge">🔥 Limited Time</div>
        <h1>Offers <em>you can't</em><br>afford to skip</h1>
        <p class="hero-sub">Curated deals on our most-loved pieces — up to 40% off</p>
    </header>
    <section class="container mx-auto px-4 py-12">

        <h2 class="text-4xl serif-font font-light mb-8 font-bloverly"></h2>
        
       

        <!-- Product Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 font-clash">
            <% offer.forEach(product=>{ %>
                <% const isWishlist = wishlist.some(e => e.variantId._id.toString() === product._id.toString() ) %>
                <div class="product-card relative">

                    <!-- Discount Badge -->
                    <% if(product.appliedOffer?.discountType == 'PERCENTAGE') { %>
                        <span class="badge-discount"><%= product.appliedOffer?.discountValue %>% OFF</span>
                    <% } else { %>
                        <span class="badge-discount"><%= product.appliedOffer?.discountValue %> FLAT OFF</span>
                    <% } %>

                    <!-- Product Image with Wishlist Button -->
                    <% if(product.status==true){%>
                        <a href="/home/product-details/<%= product.productId._id %>?size=<%= product.size %>&color=<%= product.color %>">
                            <div class="product-img-wrap bg-gray-100 rounded-2xl overflow-hidden mb-3 relative">
                                <img src="<%= product.image[0] %>" 
                                    alt="<%= product.productId.name %>" 
                                    loading="lazy"
                                    class="w-full h-full object-cover <%= product.stock <= 0 ? 'opacity-50' : '' %>">
                                <% if (product.stock <= 0) { %>
                                    <div class="absolute inset-0 flex items-center justify-center bg-opacity-40">
                                        <span class="bg-white text-black px-6 py-2 rounded-full font-semibold text-sm">
                                            Out of Stock
                                        </span>
                                    </div>
                                <% } %>
                            </div>
                        </a>
                    <% }else{%>
                        <div class="product-img-wrap bg-gray-100 rounded-2xl overflow-hidden mb-3 relative">
                            <img src="<%= product.image[0] %>" 
                                alt="<%= product.productId.name %>" 
                                loading="lazy"
                                class="w-full h-full object-cover <%= product.stock <= 0 ? 'opacity-50' : '' %>">
                            <% if (product.stock <= 0) { %>
                                <div class="absolute inset-0 flex items-center justify-center bg-opacity-40">
                                    <span class="bg-white text-black px-6 py-2 rounded-full font-semibold text-sm">
                                        Out of Stock
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                    <% if(product.stock>0&& product.status == true) {%>
                        <button 
                            data-variant="<%= product._id %>"
                            
                            class="heartBtn absolute top-3 right-3 bg-white rounded-full p-2 shadow-md hover:bg-gray-50 transition-colors z-10"
                            aria-label="Add to wishlist">
                            <i class="change <%= isWishlist==true ? 'fa-solid fa-heart' : 'fa-regular fa-heart'  %>  transition-transform duration-200"></i>
                        </button>
                    <% } %>
                    <!-- Product Info -->
                    <div class="flex justify-between items-start mb-3">
                        <% const save = product.basePrice - product.price %>
                        <div>
                            <h3 class="font-medium text-sm mb-1"><%= product.productId.name %></h3>
                            <p class="text-lg font-semibold">
                                <span class="text-gray-500 line-through">₹<%= product.discount %></span> ₹<%= product.price %>
                            </p>
                            <% if(save <= 0) { %>
                                <span class="price-save">Offer expired or getting started</span>
                            <% } else { %>
                                <span class="price-save">Save ₹<%= save.toFixed(2) %></span>
                                <span class="price-save"><%= product.appliedOffer.name ? product.appliedOffer.name:'Offer Inactive' %></span>
                            <% } %>
                            <% if (product.stock <= 0||!product.status) { %>
                                <p class="text-red-600 text-xs mt-1">Currently Unavailable</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- Add to Cart Button -->
                     
                    <button 
                        onclick="addToCart('<%= product._id %>')"
                        class="w-full py-2.5 px-4 rounded-lg font-medium text-sm transition-all 
                        <%= (product.stock <= 0 || product.status === false) 
                            ? 'bg-gray-300 text-gray-500 cursor-not-allowed' 
                            : 'bg-black text-white hover:bg-gray-800' %>"
                        <%= (product.stock <= 0 || product.status === false) ? 'disabled' : '' %>>
                        
                        <%= (product.stock <= 0 || product.status === false) 
                            ? 'Out of Stock' 
                            : 'Add to Cart' %>
                    </button>

                </div>
            <% }) %>
        </div>

        <div class="flex justify-end">
            <a  class="mr-10" href="/products">Shop more →</a>
        </div>
        
    </section>

    

    <!-- CTA Section -->
    <section class="container mx-auto px-4 py-12 font-bloverly">
        <div class="cta-section-wrap rounded-3xl overflow-hidden relative">
            <img src="/Background-image.jpg" 
            loading="lazy"
                 alt="Fashion" 
                 class="w-full h-full object-cover ">
            <div class="cta-overlay absolute inset-0 items-left justify-center text-white p-8">
