                    collections that define your unique style every season
                </p>
                <button class="cta-btn border border-white px-8 py-3 rounded-full hover:bg-white hover:text-blue-500 transition text-sm font-clash" style="font-size:clamp(16px,3vw,40px);">
                    Thank you for clicking
                </button>
            </div>
        </div>
    </section>

    <!-- Marquee -->
    <div class="bg-black text-white py-4 overflow-hidden marquee font-clash text-bold">
        <div class="whitespace-nowrap marquee-track font-bold">
            WITH UNIQUE STYLES * ELEVATE YOUR WARDROBE * WITH UNIQUE STYLES * ELEVATE YOUR WARDROBE *
        </div>
    </div>

    <!-- Footer -->
    <footer class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
            <div>
                <h3 class="footer-brand font-light mb-4 font-bloverly">#ZZRH</h3>
            </div>
            
            
        </div>
        <div class="border-t border-gray-200 pt-8 flex flex-wrap gap-4 justify-between text-xs text-gray-600">
            <p>Copyright@2025</p>
            
        </div>
    </footer>

    <script>

        const menuButton = document.getElementById('mobileMenuButton');
        const mobileMenu = document.getElementById('mobileMenu');
        const cartbtn = document.getElementById('addToCartBtn')
        const change = document.querySelectorAll('.change')
    
        change.forEach(btn=>{
            btn.addEventListener("click", function () {
                btn.classList.toggle("fa-regular");
                btn.classList.toggle("fa-solid");
                btn.classList.add("animate-heart");

                // Remove animation after it finishes
                setTimeout(() => {
                    btn.classList.remove("animate-heart");
                }, 300);
                confetti({
                    particleCount: 80,
                    spread: 70,
                    origin: { y: 0.8 }
                });
            });
        })
        let heaerbtn = document.querySelectorAll('.heartBtn') 
        heaerbtn.forEach(btn=>{
            btn.addEventListener('click',async (e)=>{
                const id = btn.dataset.variant
                const icon = btn.querySelector('.change');

                const isFilled = icon.classList.contains("fa-solid");
                
                document.getElementById('loadingOverlay').classList.add('active');
                try{

                    const request = await fetch('/profile/wishlist/update',{
                        method:"POST",
                        headers:{
                            "Content-Type" : "application/json"
                        },
                        body:JSON.stringify({
                            productId:id,
                            action:isFilled ? "ADD":"REMOVE"
                        })
                    })
                    document.getElementById('loadingOverlay').classList.remove('active');
                    const result = await request.json()
                    if(!result.success){
                        return Swal.fire({
                            toast: true,
                            icon: 'error',
                            title: result.message,
                            position: 'top-right',
                            showConfirmButton: false,
                            timer: 3000
                        });
                    }

                    return Swal.fire({
                        toast: true,
                        icon: 'success',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });

                }catch(e){

                }
            })
        })
            
        async function addToCart(variantId){
            document.getElementById('loadingOverlay').classList.add('active');
            try{
                const request = await fetch('/cart/add-cart',{
                    method:"POST",
                    headers:{
                        "Content-Type":"application/json"
                    },
                    body:JSON.stringify({
                        id:variantId,
                        userId:"<%= isLogged.id?isLogged.id:isLogged._id %>",
                        qty:1
                    })
                })
                document.getElementById('loadingOverlay').classList.remove('active');
                const result = await request.json()
                if(!result.success){
                    return Swal.fire({
                        toast: true,
                        icon: 'error',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
                return Swal.fire({
                        toast: true,
                        icon: 'success',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }catch(e){
    
                }
        }

        menuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>

    <style>
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        
        .animate-marquee {
            animation: marquee 100s linear infinite;
            display: inline-block;
        }
        .marquee {
            width: 100%;
            overflow: hidden;
            background: #000000;
            white-space: nowrap;
        }

        .marquee-track {
            display: inline-block;
            animation: marquee-left 25s linear infinite;
        }

        .marquee-track span {
            display: inline-block;
            padding: 0 2rem;
            font-size: 1.2rem;
            font-weight: 500;
        }

        @keyframes marquee-left {
        from {
            transform: translateX(100%);
        }
        to {
            transform: translateX(-100%);
        }
        }
        .marquee:hover .marquee-track,
        .marquee:active .marquee-track {
        animation-play-state: paused;
        }


    </style>
</body>
</html>