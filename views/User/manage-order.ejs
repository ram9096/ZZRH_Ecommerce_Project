<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raftaara- manage orders</title>
    <link rel="icon" type="image/x-icon" href="/favicon.png">
    <link rel="stylesheet" href="/css/output.css">
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.9);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }
        .hover-lift {
            transition: all 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        }
        .profile-avatar {
            background: linear-gradient(135deg, #6b7280 0%, #1f2937 100%);
        }
        .cancelled-overlay {
            position: relative;
        }
        .cancelled-overlay::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            pointer-events: none;
        }
</style>
<body class="bg-gray-50">
     <%- include('../Partials/nav-bar') %>
     
     <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex flex-col lg:flex-row gap-8">
            <%- include('../Partials/user-sidebar') %>

            
            
            <main class="flex-1 ml-0">
                <div class="glass-effect rounded-2xl shadow-xl border border-white/20 overflow-hidden mb-5" >
                    <div class="gradient-bg px-8 py-8 relative overflow-hidden">
                        <div class="absolute inset-0 opacity-10">
                            <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full -translate-y-32 translate-x-32"></div>
                            <div class="absolute bottom-0 left-0 w-48 h-48 bg-white rounded-full translate-y-24 -translate-x-24"></div>
                        </div>
                        <div class="relative flex items-center justify-between">
                            <div>
                                <h2 class="text-3xl font-bold text-white mb-2">Orders</h2>
                                <p class="text-gray-300">Manage your orders</p>
                            </div>
                        
                        </div>
                    </div>
                </div>
                
                <% if (order.length === 0) { %>
                    <div class="flex flex-col items-center justify-center py-16">
                        <lottie-player 
                            src="https://assets2.lottiefiles.com/packages/lf20_ydo1amjm.json"
                            background="transparent"
                            speed="1"
                            style="width: 220px; height: 220px;"
                            loop
                            autoplay>
                        </lottie-player>

                        <p class="mt-4 text-lg font-semibold text-gray-700">
                            No orders yet
                        </p>
                        <p class="text-sm text-gray-500">
                            Start shopping to see your orders here
                        </p>
                    </div>
                <% } %>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Classic Trench Coat -->
                    <% order.forEach(or=> {%>
                        <% or.orderItems.forEach(o=>{ %>
                            <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow <%= o.orderStatus === 'Cancelled' ? 'opacity-90' : '' %>">
                                <div class="aspect-[3/4] bg-gray-100 relative <%= or.orderStatus === 'cancelled' ? 'cancelled-overlay' : '' %>">
                                    <img src="<%= o.variantId.image[0] %>" 
                                        alt="<%= o.productName %>" 
                                        class="w-full h-full object-cover">
                                    
                                    <% if (or.orderStatus === 'cancelled') { %>
                                        <div class="absolute inset-0 flex items-center justify-center z-10">
                                            <div class="bg-red-600 text-white px-6 py-3 rounded-lg font-bold text-lg shadow-lg transform -rotate-12">
                                                CANCELLED
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="p-4">
                                    <div class="flex items-start justify-between mb-2">
                                        <h3 class="text-lg font-semibold text-gray-900 flex-1"><%= o.productName %> (<%= o.variantId.size %>)</h3>
                                        <% if (or.orderStatus === 'cancelled') { %>
                                            <span class="ml-2 px-2 py-1 bg-red-100 text-red-800 text-xs font-semibold rounded-full">
                                                Cancelled
                                            </span>
                                        <% } else { %>
                                            <span class="ml-2 px-2 py-1 bg-green-100 text-green-800 text-xs font-semibold rounded-full">
                                                <%= or.orderStatus || 'Active' %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <p class="text-xl font-medium text-gray-900 mb-4">₹<%= o.totalPrice %></p>
                                    <div class="flex items-center gap-2">
                                        <a href="order/details/<%= or._id %>" class="flex-1">
                                            <button class="w-full bg-black text-white py-3 px-6 rounded hover:bg-gray-800 transition-colors font-medium <%= or.orderStatus === 'cancelled' ? 'opacity-60' : '' %>">
                                                <%= or.orderStatus === 'cancelled' ? 'View Details' : 'Track' %>
                                            </button>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% }) %>
                            
                    
                </div>
            </main>
        </div>
        <% if (pagination.totalPages > 1) { %>
            <div class="flex justify-center items-center gap-4 mt-10">
    
                <!-- Previous -->
                <% if (pagination.currentPage > 1) { %>
                <a href="?page=<%= pagination.currentPage - 1 %>"
                    class="px-5 py-2 bg-white border rounded-lg hover:bg-gray-100">
                    ← Prev
                </a>
                <% } else { %>
                <span class="px-5 py-2 border rounded-lg opacity-50 cursor-not-allowed">
                    ← Prev
                </span>
                <% } %>
    
                <!-- Page info -->
                <span class="text-sm text-gray-600 font-medium">
                Page <%= pagination.currentPage %> of <%= pagination.totalPages %>
                </span>
    
                <!-- Next -->
                <% if (pagination.currentPage < pagination.totalPages) { %>
                <a href="?page=<%= parseInt(pagination.currentPage) + 1 %>"
                    class="px-5 py-2 bg-white border rounded-lg hover:bg-gray-100">
                    Next →
                </a>
                <% } else { %>
                <span class="px-5 py-2 border rounded-lg opacity-50 cursor-not-allowed">
                    Next →
                </span>
                <% } %>
    
            </div>
        <% } %>
     </div>

      <script>
        const menuButton = document.getElementById('mobileMenuButton');
        const mobileMenu = document.getElementById('mobileMenu');

        menuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>
</body>
</html>