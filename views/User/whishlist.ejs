<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/output.css">
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.9);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }
        .hover-lift {
            transition: all 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        }
        .profile-avatar {
            background: linear-gradient(135deg, #6b7280 0%, #1f2937 100%);
        }
        .cancelled-overlay {
            position: relative;
        }
        .cancelled-overlay::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            pointer-events: none;
        }
</style>
<body class="bg-gray-50">
     <%- include('../Partials/nav-bar') %>
     
     <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex gap-8">
            <%- include('../Partials/user-sidebar') %>

            
            
            <main class="flex-1 ml-0">
                <div class="glass-effect rounded-2xl shadow-xl border border-white/20 overflow-hidden mb-5" >
                    <div class="gradient-bg px-8 py-8 relative overflow-hidden">
                        <div class="absolute inset-0 opacity-10">
                            <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full -translate-y-32 translate-x-32"></div>
                            <div class="absolute bottom-0 left-0 w-48 h-48 bg-white rounded-full translate-y-24 -translate-x-24"></div>
                        </div>
                        <div class="relative flex items-center justify-between">
                            <div>
                                <h2 class="text-3xl font-bold text-white mb-2">Wishlist</h2>
                                <p class="text-gray-300">Manage your whishlist</p>
                            </div>
                        
                        </div>
                    </div>
                </div>
                
                <% if (order.length === 0) { %>
                    <div class="flex flex-col items-center justify-center py-16">
                        <lottie-player 
                            src="https://assets2.lottiefiles.com/packages/lf20_ydo1amjm.json"
                            background="transparent"
                            speed="1"
                            style="width: 220px; height: 220px;"
                            loop
                            autoplay>
                        </lottie-player>

                        <p class="mt-4 text-lg font-semibold text-gray-700">
                            No products yet
                        </p>
                        <p class="text-sm text-gray-500">
                            Start shopping to see your products here
                        </p>
                    </div>
                <% } %>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Classic Trench Coat -->
                    <% order.forEach(o=> {%>
                        
                            <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow ">
                                <div class="aspect-[3/4] bg-gray-100 relative ">
                                    <img src="/<%= o.variantId.image[0] %>" 
                                        alt="" 
                                        class="w-full h-full object-cover">
                                    
                                
                                </div>
                                <div class="p-4">
                                    <div class="flex items-start justify-between mb-2">
                                        <h3 class="text-lg font-semibold text-gray-900 flex-1"><%= o.variantId.productId.name %> (<%= o.variantId.size %>)</h3>
                                        
                                    </div>
                                    
                                    <div class="flex items-center gap-2">
                                        <% if(o.variantId.status==true&&o.variantId.stock>0) {%>
                                            <button  data-id="<%= o.variantId._id %>" class="cart w-full bg-black text-white py-3 px-6 rounded hover:bg-gray-800 transition-colors font-medium ">
                                                Add to cart
                                            </button>
                                        <% }else{ %>
                                            <div class="text-red-500">
                                                currently unavailable
                                            </div>
                                        <%} %>
                                        
                                    </div>
                                </div>
                            </div>
                        
                    <% }) %>
                            
                    
                </div>
            </main>
        </div>
        
     </div>

      <script>
        const menuButton = document.getElementById('mobileMenuButton');
        const mobileMenu = document.getElementById('mobileMenu');
        const cart = document.querySelectorAll('.cart')
        cart.forEach(c=>{

            c.addEventListener('click',async(e)=>{
                let id = c.dataset.id 

                  
                try{

                    const request = await fetch('/cart/add-cart',{
                        method:"POST",
                        headers:{
                            "Content-Type":"application/json"
                        },
                        body:JSON.stringify({
                            id:id,
                            userId:"<%= isLogged.id %>",
                            qty:1
                        })
                    })
                    const result = await request.json()
                    
                    if(!result.success){
                        return Swal.fire({
                            toast: true,
                            icon: 'error',
                            title: result.message,
                            position: 'top-right',
                            showConfirmButton: false,
                            timer: 3000
                        });
                    }
                    return Swal.fire({
                        toast: true,
                        icon: 'success',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }catch(e){
    
                }
            })
        })
        menuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>
</body>
</html>