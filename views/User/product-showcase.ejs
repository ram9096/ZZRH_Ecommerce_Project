<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#Raftaara - Fashion Store</title>
    <link rel="stylesheet" href="/css/output.css">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
     <link rel="preload" href="/BLOVERLY.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/ClashDisplay-Regular.woff" as="font" type="font/woff" crossorigin>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap');
        
        .serif-font {
            font-family: 'Playfair Display', serif;
        }
        
        .product-card {
            transition: transform 0.3s ease;
            position: relative;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
        }

        .out-of-stock-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .out-of-stock-badge {
            background: #dc2626;
            color: white;
            padding: 8px 16px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
        }

        .low-stock-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: #f59e0b;
            color: white;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
            z-index: 5;
        }

        .product-card.out-of-stock {
            opacity: 0.7;
            pointer-events: none;
        }

        .product-card.out-of-stock img {
            filter: grayscale(50%);
        }

       
        .font-bloverly {
            font-family: "bloverly", system-ui, sans-serif;
        }
        .font-clash {
            font-family: "Clash-display", system-ui, sans-serif;
        }
    </style>
</head>
<body class="bg-white">
    <% if (error) { %>
        <script>
            Swal.fire({
                toast: true,
                icon: 'error',
                title: '<%=error%>',
                position: 'top-right',
                showConfirmButton: false,
                timer: 3000
            });
        </script>
    <% } %>
     
    <% if(isLogged) {%>
            <%- include('../Partials/nav-bar') %>
        <% } %>
        
        <% if(!isLogged){ %>
            <div class="flex items-center justify-between">

                <a href="/">
                    <div class="text-[60px] md:text-[125px] font-bloverly tracking-tight" style="font-family: bloverly;font-weight: lighter;">
                        #Raftaara
                    </div>
                </a>

                <a href="/login">
                    <button class="hidden md:block border border-black px-6 py-2 rounded-md text-sm font-clash hover:bg-black hover:text-white transition">
                        Login / Sign-up
                    </button>
                </a>

            </div>
        <% } %>

    <section class="container mx-auto px-4 p">
        <div class="flex flex-col lg:flex-row gap-5">
            <!-- Filter Sidebar -->
            <aside class="lg:w-64 shrink-0">
                <div class="bg-white rounded-lg border border-gray-200 p-6 sticky top-4">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-xl font-clash font-medium">Filter</h3>
                        <a href="/products">
                            <button id="resetFilters" class="text-sm text-gray-600 hover:text-black">Reset filters</button>
                        </a>
                    </div>

                    <!-- Category Filter -->
                    <div class="mb-6 pb-6 border-b border-gray-200">
                        <h4 class="font-medium mb-3 font-clash text-sm">Category</h4>
                        <select id="category" name="category" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black">
                            <option value="ALL">All Categories</option>
                            <% category.forEach(c => { %>
                                <option value="<%= c.categoryName %>"><%= c.categoryName %></option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Price Range Filter -->
                    <div class="mb-6 pb-6 border-b border-gray-200">
                        <h4 class="font-medium mb-3 font-clash text-sm">Price range</h4>
                        <div class="space-y-3">
                            <div class="flex gap-2">
                                <input type="number" placeholder="Min" class="w-full border border-gray-300 rounded px-3 py-2 text-sm" id="minPrice">
                                <input type="number" placeholder="Max" class="w-full border border-gray-300 rounded px-3 py-2 text-sm" id="maxPrice">
                            </div>
                        </div>
                    </div>

                    <!-- Size Filter -->
                    <div class="mb-6 pb-6 border-b border-gray-200">
                        <h4 class="font-medium mb-3 font-clash text-sm">Size</h4>
                        <div class="grid grid-cols-3 gap-2">
                            <select name="size" id="size">
                                <option value="">All</option>
                                <option value="XS">XS</option>
                                <option value="Small">S</option>
                                <option value="Medium">M</option>
                                <option value="Large">L</option>
                                <option value="XL">XL</option>
                                <option value="XXL">XXL</option>
                            </select>
                        </div>
                    </div>

                    <!-- Color Filter -->
                    <div class="mb-6">
                        <h4 class="font-medium mb-3 font-clash text-sm">Color</h4>
                        <div class="grid grid-cols-2 gap-2">
                            <select name="color" id="color">
                                <option value="">All</option>
                                <% color.forEach(c => { %>
                                    <option value="<%= c %>"><%= c %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <!-- Sort Filter -->
                    <div class="mb-6">
                        <h4 class="font-medium mb-3 font-clash text-sm">Sort</h4>
                        <div class="grid grid-cols-1 gap-2">
                            <select name="sort" id="sort">
                                <option value="">All</option>
                                <option value="HIGH_TO_LOW">High to low</option>
                                <option value="LOW_TO_HIGH">Low to high</option>
                                <option value="A_Z">aA-zZ</option>
                                <option value="Z_A">zZ-aA</option>
                            </select>
                        </div>
                    </div>

                    <button id="filter" class="w-full bg-black text-white py-3 rounded-md font-clash text-sm hover:bg-gray-800 transition">
                        Show Results
                    </button>
                </div>
            </aside>

            <!-- Products Grid -->
           <div class="flex-1">
            <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 ml-5">
                <% product.forEach(product => { %> 
                <% const stock = product.stock || 0; %>
                <% const isOutOfStock = stock <= 0; %>
                <% const isLowStock = stock > 0 && stock < 5; %>
                    <% const isWishlist = wishlist.some(e => e.variantId._id.toString() === product._id.toString() ) %>
                    <div class="max-w-sm product-card <%= isOutOfStock ? 'out-of-stock' : '' %>">
                        <div class="bg-white rounded-lg overflow-hidden shadow-sm relative group">

                            <% if (isLowStock) { %>
                                <div class="low-stock-badge">
                                    Only <%= stock %> left
                                </div>
                            <% } %>

                            <!-- Wishlist Button -->
                             <% if(isLogged) {%>
                                <button 
                                    data-variant="<%= product._id %>"
                                    
                                    class="heartBtn absolute top-3 right-3 bg-white rounded-full p-2 shadow-md hover:bg-gray-50 transition-colors z-10"
                                    aria-label="Add to wishlist">
                                    <i class="change <%= isWishlist==true ? 'fa-solid fa-heart' : 'fa-regular fa-heart'  %>  transition-transform duration-200"></i>
                                </button>
                            <% } %>

                            <!-- Product Image with Link -->
                            <% if (!isOutOfStock) { %>
                                <a href="/home/product-details/<%= product.productId._id %>?size=<%= product.size %>&color=<%= product.color %>">
                            <% } %>
                                <div class="bg-gray-100 aspect-3/4 flex items-center justify-center relative overflow-hidden">
                                    <img 
                                        src="<%= product.image[0] %>" 
                                        alt="<%= product.products.name %>" 
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                                    />
                                    <% if (isOutOfStock) { %>
                                        <div class="out-of-stock-overlay">
                                            <div class="out-of-stock-badge">Out of Stock</div>
                                        </div>
                                    <% } %>
                                </div>
                            <% if (!isOutOfStock) { %>
                                </a>
                            <% } %>

                            <!-- Product Info & Actions -->
                            <div class="p-4 text-center">
                                <h3 class="text-base font-normal text-gray-900 mb-1">
                                    <%= product.products[0].name %>
                                </h3>
                                <p class="text-base text-gray-900 mb-3">₹<%= product.price %></p>

                                <!-- Add to Cart Button -->
                                 <% if(isLogged) {%>
                                    <button
                                        class="add-to-cart-btn w-full py-2 px-4 rounded-md text-sm font-medium transition-all duration-200
                                            <%= isOutOfStock 
                                                ? 'bg-gray-100 text-gray-400 cursor-not-allowed' 
                                                : 'bg-black text-white hover:bg-gray-800 active:scale-95' %>"
                                        onclick="addToCart('<%= product._id %>')"
                                        <%= isOutOfStock ? 'disabled' : '' %>
                                    >
                                        <% if (isOutOfStock) { %>
                                            Unavailable
                                        <% } else { %>
                                            Add to Cart
                                        <% } %>
                                    </button>
                                <% } %>
                            </div>

                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
    </section>

    <!-- Footer -->
    <footer class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
            <div>
                <h3 class="text-[60px] md:text-[125px] font-light mb-4 font-bloverly">#ZZRH</h3>
            </div>
            
            <div>
                <h4 class="font-medium mt-10 mb-3 font-clash">Navigation</h4>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li><a href="#" class="hover:text-gray-900">About Us</a></li>
                    <li><a href="#" class="hover:text-gray-900">Collection</a></li>
                    <li><a href="#" class="hover:text-gray-900">Contact</a></li>
                </ul>
            </div>
            
            <div>
                <h4 class="font-medium mb-3 mt-10 font-clash">Collection</h4>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li><a href="#" class="hover:text-gray-900">New Arrival</a></li>
                    <li><a href="#" class="hover:text-gray-900">Men's</a></li>
                    <li><a href="#" class="hover:text-gray-900">Women's</a></li>
                    <li><a href="#" class="hover:text-gray-900">Collection</a></li>
                </ul>
            </div>
            
            <div>
                <h4 class="font-medium mb-3 mt-10 font-clash">Contact Us</h4>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li>###@gmail.com</li>
                    <li>##91-000000</li>
                </ul>
            </div>
        </div>
        <div class="border-t border-gray-200 pt-8 flex justify-between text-xs text-gray-600">
            <p>Copyright@2025</p>
            <div class="space-x-6">
                <a href="#" class="hover:text-gray-900">Terms and conditions</a>
                <a href="#" class="hover:text-gray-900">Privacy Policy</a>
            </div>
        </div>
    </footer>

    <script>
        const menuButton = document.getElementById('mobileMenuButton');
        const mobileMenu = document.getElementById('mobileMenu');

        const change = document.querySelectorAll('.change')
    
        change.forEach(btn=>{
            btn.addEventListener("click", function () {
                btn.classList.toggle("fa-regular");
                btn.classList.toggle("fa-solid");
                btn.classList.add("animate-heart");

                // Remove animation after it finishes
                setTimeout(() => {
                    btn.classList.remove("animate-heart");
                }, 300);
                confetti({
                    particleCount: 80,
                    spread: 70,
                    origin: { y: 0.8 }
                });
            });
        })
        let heaerbtn = document.querySelectorAll('.heartBtn') 
        heaerbtn.forEach(btn=>{
            btn.addEventListener('click',async (e)=>{
                const id = btn.dataset.variant
                const icon = btn.querySelector('.change');

                const isFilled = icon.classList.contains("fa-solid");
                

                try{

                    const request = await fetch('/profile/wishlist/update',{
                        method:"POST",
                        headers:{
                            "Content-Type" : "application/json"
                        },
                        body:JSON.stringify({
                            productId:id,
                            action:isFilled ? "ADD":"REMOVE"
                        })
                    })
                    const result = await request.json()
                    if(!result.success){
                        return Swal.fire({
                            toast: true,
                            icon: 'error',
                            title: result.message,
                            position: 'top-right',
                            showConfirmButton: false,
                            timer: 3000
                        });
                    }

                    return Swal.fire({
                        toast: true,
                        icon: 'success',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });

                }catch(e){

                }
            })
        })

        async function addToCart(variantId){

            try{
                const request = await fetch('/cart/add-cart',{
                    method:"POST",
                    headers:{
                        "Content-Type":"application/json"
                    },
                    body:JSON.stringify({
                        id:variantId,
                        userId:"<%= isLogged.id %>",
                        qty:1
                    })
                })
                const result = await request.json()
                if(!result.success){
                    return Swal.fire({
                        toast: true,
                        icon: 'error',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
                return Swal.fire({
                        toast: true,
                        icon: 'success',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }catch(e){
    
                }
        }
            

        function ProductsRendering(products) {
            const grid = document.getElementById("productGrid");
            grid.innerHTML = "";

            if (!products || products.length === 0) {
                grid.innerHTML = `<p class="text-gray-500 col-span-full text-center py-8">No products found</p>`;
                return;
            }
            products.forEach(product => {
                const stock = product.stock || 0;
                const isOutOfStock = stock <= 0;
                const isLowStock = stock > 0 && stock < 5;
                const cardClass = isOutOfStock ? 'out-of-stock' : '';
                
                const lowStockBadge = isLowStock ? `
                    <div class="low-stock-badge">
                        Only ${stock} left
                    </div>
                ` : '';

                const outOfStockOverlay = isOutOfStock ? `
                    <div class="out-of-stock-overlay">
                        <div class="out-of-stock-badge">
                            Out of Stock
                        </div>
                    </div>
                ` : '';

                const linkStart = !isOutOfStock ? 
                    `<a href="/home/product-details/${product.productId}?size=${product.size}&color=${product.color}">` : '';
                const linkEnd = !isOutOfStock ? `</a>` : '';

                grid.insertAdjacentHTML("beforeend", `
                    <div class="max-w-sm product-card ${cardClass}">
                        ${linkStart}
                            <div class="bg-white rounded-lg overflow-hidden shadow-sm relative">
                                ${lowStockBadge}
                                <div class="bg-gray-100 aspect-[3/4] flex items-center justify-center relative">
                                    <img 
                                        src="${product.image[0]}" 
                                        alt="${product.products.name}" 
                                        class="w-full h-full object-cover"
                                    />
                                    ${outOfStockOverlay}
                                </div>
                                <div class="p-6 text-center">
                                    <h3 class="text-base font-normal text-gray-900 mb-1">
                                        ${product.products[0].name}
                                    </h3>
                                    <p class="text-base text-gray-900">₹${product.price}</p>
                                </div>
                            </div>
                        ${linkEnd}
                    </div>
                `);
            });
        }

        document.getElementById('filter').addEventListener('click', async () => {
            const category = document.getElementById('category').value || 'all';
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;
            const size = document.getElementById('size').value || null;
            const sort = document.getElementById('sort').value;
            const color = document.getElementById('color').value || null;

            try {
                const res = await fetch('/products/filter', {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        category,
                        minPrice,
                        maxPrice,
                        size,
                        color,
                        sort
                    })
                });

                const data = await res.json();

                if (!data.success) {
                    Swal.fire({
                        toast: true,
                        icon: "error",
                        title: data.message || "ERROR",
                        position: "top-right",
                        showConfirmButton: false,
                        timer: 3000,
                    });
                    return;
                }

                ProductsRendering(data.product);
            } catch (e) {
                console.log("Server error");
                Swal.fire({
                    toast: true,
                    icon: "error",
                    title: e.message,
                    position: "top-right",
                    showConfirmButton: false,
                    timer: 3000,
                });
            }
        });

        menuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>
</body>
</html>