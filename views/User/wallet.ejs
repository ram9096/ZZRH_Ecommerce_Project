<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wallet</title>
    <link rel="icon" type="image/x-icon" href="/favicon.png">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/@lottiefiles/dotlottie-wc@0.8.11/dist/dotlottie-wc.js" type="module"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }
        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.9);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }
        .hover-lift {
            transition: all 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        }
        .profile-avatar {
            background: linear-gradient(135deg, #6b7280 0%, #1f2937 100%);
        }
    </style>
</head>
<body class="bg-gray-50 bg-linear-to-br from-gray-50 via-gray-100 to-gray-50 min-h-screen ">
    <%- include('../Partials/nav-bar') %>
    <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex flex-col lg:flex-row gap-8">
            <%- include('../Partials/user-sidebar') %>
            <!-- Sidebar -->
    
            <!-- Main Content -->
            <div class="flex-1">
                <!-- Breadcrumb -->
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-8">
                    <a href="#" class="hover:text-gray-900">Profile</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-gray-900 font-medium">Wallet</span>
                </div>
    
                <!-- Wallet Card -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden max-w-4xl">
                    <!-- Header -->
                    <div class="bg-gradient-to-r from-gray-800 to-gray-900 p-8">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center">
                                    <i class="fa-brands fa-rockrms text-5xl "></i>
                                </div>
                                <div>
                                    <h2 class="text-xl font-semibold text-white">Wallet</h2>
                                    <p class="text-gray-400 text-sm">Manage your balance & transactions</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                                <span class="text-green-400 text-sm font-medium">LIVE</span>
                            </div>
                        </div>
                    </div>
    
                    <!-- Balance Section -->
                    <div class="p-8">
                        <div class="bg-gray-50 rounded-xl p-8 text-center mb-8">
                            <div class="flex items-center justify-center gap-3 mb-2">
                                
                                <span class="text-5xl font-bold text-gray-900"><i class="fa-brands fa-rockrms"></i> <%= balance %></span>
                            </div>
                            <p class="text-gray-500 text-sm uppercase tracking-wide">Current Balance</p>
                        </div>
    
                        <!-- Quick Actions -->
                        
    
                        <!-- Recent Transactions -->
                        <div>
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Recent Transactions</h3>
                            <div class="space-y-3">
                                <!-- Transaction 1 -->
                                 <% transaction.forEach(t=>{ %>
                                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                                                
                                                <dotlottie-wc
                                                    src="https://lottie.host/41b191c1-b3ca-4cb1-9d50-7860510e4ab3/b8ozzqlhaO.lottie"
                                                    style="width: 500px;height: 500px"
                                                    autoplay
                                                    loop
                                                    ></dotlottie-wc>
                                            </div>
                                            <div>
                                                <p class="font-medium text-gray-900"><%= t.reason %></p>
                                                <p class="text-sm text-gray-500"><%= t.createdAt.toDateString() %></p>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-1xl font-semibold <%= t.type == "credit" ? 'text-green-600':'text-red-600' %> "><%= t.type == "credit" ? '+':'-' %> <i class="fa-brands fa-rockrms"></i> <%= t.amount %></p>
                                            <p class="text-xs text-gray-500">Completed</p>
                                        </div>
                                    </div>
                                <% }) %>
    
                                <!-- Transaction 2 -->
                                <!-- <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                            <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900">Order Payment</p>
                                            <p class="text-sm text-gray-500">Feb 11, 2026 • 4:15 PM</p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <p class="font-semibold text-red-600">-₹1,299.00</p>
                                        <p class="text-xs text-gray-500">Completed</p>
                                    </div>
                                </div> -->
    
                                
                            </div>
                        </div>
    
                        <!-- View All Button -->
                        <div class="mt-6 text-center">
                            <button class="text-gray-700 hover:text-gray-900 font-medium text-sm flex items-center gap-2 mx-auto">
                                View All Transactions
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </button>
                        </div>
                    </div>
    
                    <!-- Footer -->
                    <div class="px-8 pb-8 flex items-center justify-between text-sm text-gray-500">
                        <a href="#" class="flex items-center gap-2 hover:text-gray-900 transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
                            </svg>
                            Back
                        </a>
                        <span class="text-gray-400">Secured by encryption</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>