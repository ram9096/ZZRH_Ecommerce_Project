<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - Raftaara</title>
    <link rel="stylesheet" href="/css/output.css">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
     <link rel="preload" href="/BLOVERLY.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/ClashDisplay-Regular.woff" as="font" type="font/woff" crossorigin>
   
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap');
        
        #zoomContainer:hover {
            border: 1px solid #000;
        }
        #zoomContainer {
            cursor: zoom-in;
        }
        #zoomContainer img {
            transform-origin: center;
        }

       
        .font-bloverly {
            font-family: "bloverly", system-ui, sans-serif;
        }
        .font-clash {
            font-family: "Clash-display", system-ui, sans-serif;
        }
        
        .quantity-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: black;
            color: white;
            border: none;
            cursor: pointer;
            font-size: 18px;
        }
        
        .quantity-btn:disabled {
            background: #9ca3af;
            cursor: not-allowed;
        }
        
        .quantity-input {
            width: 50px;
            text-align: center;
            border: 1px solid #e5e7eb;
            padding: 4px;
        }
        
        .stock-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
        }
        
        .stock-low {
            background-color: #fef3c7;
            color: #92400e;
        }
        
        .stock-out {
            background-color: #fee2e2;
            color: #991b1b;
        }
        @keyframes heartPop {
            0% { transform: scale(1); }
            30% { transform: scale(1.4); }
            60% { transform: scale(0.9); }
            100% { transform: scale(1); }
        }

        .animate-heart {
            animation: heartPop 0.3s ease;
        }
        .animate-fade-in {
      animation: fadeIn 0.4s ease-out;
    }
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    @keyframes fadeIn {
      0% { opacity: 0; transform: translateY(-10px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .loading-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
      z-index: 9999;
      justify-content: center;
      align-items: center;
    }
    .loading-overlay.active {
      display: flex;
    }
    .spinner {
      border: 4px solid rgba(255, 255, 255, 0.2);
      border-top: 4px solid #ef4444;
      border-radius: 50%;
      width: 60px;
      height: 60px;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    </style>
</head>
<body class="bg-white">
    <div id="loadingOverlay" class="loading-overlay">
    <div class="text-center">
      <div class="spinner mx-auto mb-4"></div>
      <p class="text-white text-xl font-semibold">loading...</p>
      <p class="text-gray-300 text-sm mt-2">Please wait while we process your request</p>
    </div>
  </div>
    <% if (error) { %>
        <script>
            Swal.fire({
                toast: true,
                icon: 'error',
                title: '<%=error%>',
                position: 'top-right',
                showConfirmButton: false,
                timer: 3000
            });
        </script>
    <% } %>
    
    <!-- Header -->
    <header>
        
        <% if(isLogged) {%>
            <%- include('../Partials/nav-bar') %>
        <% } %>
        
        <% if(!isLogged){ %>
            <div class="flex items-center justify-between">

                <a href="/">
                    <div class="text-[60px] md:text-[125px] font-bloverly tracking-tight" style="font-family: bloverly;font-weight: lighter;">
                        #Raftaara
                    </div>
                </a>

                <a href="/login">
                    <button class="hidden md:block border border-black px-6 py-2 rounded-md text-sm font-clash hover:bg-black hover:text-white transition">
                        Login / Sign-up
                    </button>
                </a>

            </div>
        <% } %>
    </header>

    

    <% const selectedVariant = variant?.[0] || variant %>

    <main class="container mx-auto px-8">
        <nav class="text-sm text-gray-500 mb-6 font-clash" aria-label="Breadcrumb">
            <ol class="flex flex-wrap items-center gap-1">
                <li><a href="/" class="hover:text-black">Home</a></li>
                <li>/</li>
                <% if (product?.categoryId?.categoryName) { %>
                    <li>
                        <a href="/home?category=<%= product.categoryId._id %>" class="hover:text-black">
                            <%= product.categoryId.categoryName %>
                        </a>
                    </li>
                    <li>/</li>
                <% } %>
                <li class="text-black font-medium truncate max-w-50">
                    <%= product.name %>
                </li>
            </ol>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Image Gallery -->
            <div class="space-y-4">
                <div class="bg-gray-200 rounded-lg aspect-square">
                    <div id="zoomContainer" class="bg-gray-200 rounded-lg aspect-square overflow-hidden relative">
                        <img id="img1" src="<%= selectedVariant?.image[0] %>" class="w-full h-full object-cover transition-transform duration-200" alt="">
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-4">
                    <div class="bg-gray-200 rounded-lg aspect-square relative overflow-hidden border-2 border-black transition-all duration-200" id="thumb1">
                        <img id="img2" class="cursor-pointer w-full h-full object-cover" src="<%= selectedVariant?.image[0] %>" alt="">
                    </div>
                    <div class="bg-gray-200 rounded-lg aspect-square relative overflow-hidden border-2 border-transparent transition-all duration-200" id="thumb2">
                        <img id="img3" class="cursor-pointer w-full h-full object-cover" src="<%= selectedVariant?.image[1] %>" alt="">
                    </div>
                    <div class="bg-gray-200 rounded-lg aspect-square relative overflow-hidden border-2 border-transparent transition-all duration-200" id="thumb3">
                        <img id="img4" class="cursor-pointer w-full h-full object-cover" src="<%= selectedVariant?.image[2] %>" alt="">
                    </div>
                </div>
            </div>

            <!-- Product Details -->
            <div class="space-y-6 font-clash">
                <div>
                    <h1 class="text-4xl font-light mb-4"><%= product.name %></h1>
                    <div class="flex items-center gap-4">
                        <p id="discount" class="text-xl text-gray-500 line-through">
                            ₹<%= selectedVariant?.discount %>
                        </p>
                        <p id="price" class="text-3xl font-semibold text-black">
                            ₹<%= selectedVariant?.price %>
                        </p>
                    </div>
                    
                    <!-- Stock Badge -->
                    <div class="mt-3" id="stockBadgeContainer">
                        <% if (selectedVariant?.stock <= 0) { %>
                            <span class="stock-badge stock-out">Out of Stock</span>
                        <% } else if (selectedVariant?.stock < 5) { %>
                            <span class="stock-badge stock-low">Only <%= selectedVariant?.stock %> left in stock!</span>
                        <% } %>
                    </div>
                </div>

                <!-- Description -->
                <div class="border border-gray-300 rounded-lg p-6">
                    <h3 class="font-semibold mb-2">Description</h3>
                    <p class="text-sm text-gray-600"><%= product.description %></p>
                </div>

                <!-- Color Selection -->
                <div>
                    <h3 class="font-semibold mb-3">Color</h3>
                    <select class="border rounded px-3 py-2" id="color">
                        <% color.forEach(c => { %>
                            <option value="<%= c %>"<%= c==selectedVariant.color?'selected':'' %>><%= c %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- Size Selection -->
                <div>
                    <h3 class="font-semibold mb-3">Size</h3>
                    <select class="border rounded px-3 py-2" id="size">
                        <% size.forEach(s => { %>
                            <option value="<%= s %>" <%= s==selectedVariant.size?'selected':'' %>><%= s %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- Quantity -->
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="font-semibold mb-3">Quantity</h3>
                        <div class="flex items-center gap-2">
                            <button class="quantity-btn" id="decreaseBtn">-</button>
                            <input type="text" value="1" class="quantity-input" id="quantityInput" readonly>
                            <button class="quantity-btn" id="increaseBtn">+</button>
                        </div>
                    </div>
                    <% if(isLogged&&selectedVariant.status==true&&selectedVariant.stock>0){ %>
                        <button id="heartBtn"  class="text-red-500 text-3xl hover:text-red-600" data-variant="<%= selectedVariant._id %>">
                            <i id="change" class="fa-regular fa-heart transition-transform duration-200"></i>
                        </button>
                    <% } %>
                </div>

                <!-- Buttons -->

                <% if(isLogged){ %>

                    <div class="space-y-3">
                        <!-- <button id="buyNowBtn" class="w-full bg-black text-white py-3 rounded hover:bg-gray-800 transition disabled:bg-gray-400 disabled:cursor-not-allowed">
                            Buy now
                        </button> -->
                        <form  id="cartForm">
                            <button type="submit" id="addToCartBtn" class="w-full border border-black text-black py-3 rounded hover:bg-gray-50 transition disabled:border-gray-400 disabled:text-gray-400 disabled:cursor-not-allowed" <%= (selectedVariant.stock<=0||selectedVariant.status==false)?'disabled':'' %>>
                                Add to cart
                            </button>
                        </form>
                    </div>

                <% }else{ %>
                    <!-- Blurred buttons -->
                    <div class="relative">
                        <div class="blur-sm pointer-events-none">
                            <button
                                class="w-full bg-black text-white py-3 rounded mb-3">
                                Buy now
                            </button>

                            <button
                                class="w-full border border-black text-black py-3 rounded">
                                Add to cart
                            </button>
                        </div>

                        <!-- Overlay Message -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <a href="/login"
                            class="bg-white px-4 py-2 rounded shadow text-sm font-medium hover:bg-gray-100">
                                Login or Register to order
                            </a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Customer Reviews Section -->
        <section class="mt-16">
            <h2 class="text-3xl font-semibold mb-8">Customer Reviews</h2>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-1">
                    <div class="flex items-baseline gap-2 mb-4">
                        <span class="text-5xl font-bold">4.2</span>
                        <div class="flex text-yellow-400">
                            <span class="star-filled">★★★★</span>
                            <span class="star-empty">★</span>
                        </div>
                    </div>
                    <p class="text-sm text-gray-600 mb-6">Based on 121 reviews</p>
                </div>
            </div>
        </section>

        <!-- Related Products -->
        <section class="container mx-auto px-4 py-12">
            <h2 class="text-4xl serif-font font-light mb-8 font-bloverly">Related products</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 font-clash">
                <% Relatedproducts.forEach(product => { %>
                    <a href="/home/product-details/<%= product.products[0]._id %>?size=<%= product.size %>&color=<%= product.color %>">
                        <div class="product-card">
                            <div class="bg-gray-100 rounded-2xl overflow-hidden mb-3" style="height: 350px;">
                                <img src="<%= product.image[0] %>" alt="Product" class="w-full h-full object-cover">
                            </div>
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-medium text-sm mb-1"><%= product.products[0].name %></h3>
                                    <p class="text-lg font-semibold">₹<%= product.price %></p>
                                </div>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        </section>
    </main>

    <script>
        let currentStock = Number('<%= selectedVariant?.stock || 0 %>');
        let currentVariantId = "<%= selectedVariant._id %>"
        const menuButton = document.getElementById('mobileMenuButton');
        const mobileMenu = document.getElementById('mobileMenu');
        const price = document.getElementById('price');
        const discount = document.getElementById('discount');
        const img1 = document.getElementById('img1');
        const img2 = document.getElementById('img2');
        const img3 = document.getElementById('img3');
        const img4 = document.getElementById('img4');
        const sizeSelect = document.getElementById('size');
        const quantityInput = document.getElementById('quantityInput');
        const increaseBtn = document.getElementById('increaseBtn');
        const decreaseBtn = document.getElementById('decreaseBtn');
        const buyNowBtn = document.getElementById('buyNowBtn');
        const addToCartBtn = document.getElementById('addToCartBtn');

        const thumbnail = [img2, img3, img4];
        thumbnail.forEach(t => {
            t.addEventListener('click', () => {
                let temp = img1.src;
                img1.src = t.src;
                t.src = temp;
            });
        });

        const zoomContainer = document.getElementById('zoomContainer');
        const ZOOM_LEVEL = 2.5;
        
        zoomContainer.addEventListener('mousemove', (e) => {
            const rect = zoomContainer.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.width) * 100;
            img1.style.transformOrigin = `${x}% ${y}%`;
            img1.style.transform = `scale(${ZOOM_LEVEL})`;
        });

        zoomContainer.addEventListener('mouseleave', () => {
            img1.style.transform = 'scale(1)';
            img1.style.transformOrigin = 'center';
        });
        
        const stockBadgeContainer = document.getElementById('stockBadgeContainer');
        const change = document.getElementById('change')
    
        change.addEventListener("click", function () {
            change.classList.toggle("fa-regular");
            change.classList.toggle("fa-solid");
            change.classList.add("animate-heart");

            // Remove animation after it finishes
            setTimeout(() => {
                change.classList.remove("animate-heart");
            }, 300);
            confetti({
                particleCount: 80,
                spread: 70,
                origin: { y: 0.8,x:0.9 }
            });
        });
        function updateStockDisplay(stock) {
            currentStock = stock;
            let badgeHTML = '';
            
            if (stock <= 0) {
                badgeHTML = '<span class="stock-badge stock-out">Out of Stock</span>';
                buyNowBtn.disabled = true;
                addToCartBtn.disabled = true;
                increaseBtn.disabled = true;
                decreaseBtn.disabled = true;
            } else if (stock < 11) {
                badgeHTML = `<span class="stock-badge stock-low">Only ${stock} left in stock!</span>`;
                buyNowBtn.disabled = false;
                addToCartBtn.disabled = false;
                updateQuantityButtons();
            } else {
                badgeHTML = '';
                addToCartBtn.disabled = false;
                updateQuantityButtons();
            }
            
            stockBadgeContainer.innerHTML = badgeHTML;
        }
        let heaerbtn = document.getElementById('heartBtn') 
        heaerbtn.addEventListener('click',async ()=>{
            const id = heaerbtn.dataset.variant
            const isFilled = change.classList.contains("fa-solid")
            
            document.getElementById('loadingOverlay').classList.add('active');
            try{

                const request = await fetch('/profile/wishlist/update',{
                    method:"POST",
                    headers:{
                        "Content-Type" : "application/json"
                    },
                    body:JSON.stringify({
                        productId:id,
                        action:isFilled ? "ADD":"REMOVE"
                    })
                })
                const result = await request.json()
                document.getElementById('loadingOverlay').classList.remove('active');
                if(!result.success){
                    return Swal.fire({
                        toast: true,
                        icon: 'error',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }

                return Swal.fire({
                    toast: true,
                    icon: 'success',
                    title: result.message,
                    position: 'top-right',
                    showConfirmButton: false,
                    timer: 3000
                });

            }catch(e){

            }
        })
        const cartForm = document.getElementById('cartForm')

        cartForm.addEventListener('submit',async(e)=>{
            e.preventDefault()
            document.getElementById('loadingOverlay').classList.add('active');
            try{
                const request = await fetch('/cart/add-cart',{
                    method:"POST",
                    headers:{
                        "Content-Type":"application/json"
                    },
                    body:JSON.stringify({
                        id:currentVariantId,
                        userId:"<%= isLogged.id?isLogged.id:isLogged._id %>",
                        qty:quantityInput.value
                    })
                })
                const result = await request.json()
                document.getElementById('loadingOverlay').classList.remove('active');
                if(!result.success){
                    return Swal.fire({
                        toast: true,
                        icon: 'error',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
                return Swal.fire({
                        toast: true,
                        icon: 'success',
                        title: result.message,
                        position: 'top-right',
                        showConfirmButton: false,
                        timer: 3000
                    });
            }catch(e){

            }
        })


        function clampQuantity() {
            let qty = parseInt(quantityInput.value);

            if (qty < 1) qty = 1;
            if (qty > currentStock) qty = currentStock;

            quantityInput.value = qty;
        }


        function updateQuantityButtons() {
            const qty = parseInt(quantityInput.value);

            decreaseBtn.disabled = qty <= 1;
            increaseBtn.disabled = qty >= currentStock;

            if (currentStock <= 0) {
                decreaseBtn.disabled = true;
                increaseBtn.disabled = true;
                quantityInput.value = 0;
            }
        }


        increaseBtn.addEventListener('click', () => {
            quantityInput.value = parseInt(quantityInput.value) + 1;
            clampQuantity();
            updateQuantityButtons();
        });

        decreaseBtn.addEventListener('click', () => {
            quantityInput.value = parseInt(quantityInput.value) - 1;
            clampQuantity();
            updateQuantityButtons();
        });


        const mainImage = document.getElementById('img1');
        const thumb1 = document.getElementById('thumb1');
        const thumb2 = document.getElementById('thumb2');
        const thumb3 = document.getElementById('thumb3');

        function setActiveThumb(activeThumb) {
            thumb1.classList.remove('border-black');
            thumb1.classList.add('border-transparent');
            thumb2.classList.remove('border-black');
            thumb2.classList.add('border-transparent');
            thumb3.classList.remove('border-black');
            thumb3.classList.add('border-transparent');
            activeThumb.classList.remove('border-transparent');
            activeThumb.classList.add('border-black');
        }

        img2.addEventListener('click', function() {
            mainImage.src = this.src;
            setActiveThumb(thumb1);
        });

        img3.addEventListener('click', function() {
            mainImage.src = this.src;
            setActiveThumb(thumb2);
        });

        img4.addEventListener('click', function() {
            mainImage.src = this.src;
            setActiveThumb(thumb3);
        });

        setActiveThumb(thumb1);

        document.getElementById('color').addEventListener('change', async () => {
            const id = '<%= product._id %>';
            const color = document.getElementById('color').value;
            document.getElementById('loadingOverlay').classList.add('active');
            try {
                const res = await fetch(`/home/product-details/${id}`, {
                    method: "POST",
                    headers: {
                        "Content-type": "application/json"
                    },
                    body: JSON.stringify({
                        id: id,
                        type: "color",
                        value: color
                    })
                });
                const data = await res.json();
                document.getElementById('loadingOverlay').classList.remove('active');
                if (!data.success) return;
                
                img1.src = `${data.product.image[0]}`;
                img2.src = `${data.product.image[0]}`;
                img3.src = `${data.product.image[1]}`;
                img4.src = `${data.product.image[2]}`;
                sizeSelect.innerHTML = '';
                currentVariantId = data.product._id
                data.product.sizes.forEach((s, i) => {
                    const option = document.createElement('option');
                    option.value = s.size;
                    option.innerHTML = s.size;
                    sizeSelect.appendChild(option);
                });
                
                const firstSize = data.product.sizes[0];
                discount.innerHTML = `₹${firstSize.discount}`;
                price.innerHTML = `₹${firstSize.price}`;
                updateStockDisplay(firstSize.stock || 0);
                quantityInput.value = 1;
            } catch (e) {
                console.error(e);
            }
        });

        document.getElementById('size').addEventListener('change', async () => {
            const id = '<%= product._id %>';
            const size = document.getElementById('size').value;
            const color = document.getElementById('color').value;
            try {
                const res = await fetch(`/home/product-details/${id}`, {
                    method: "POST",
                    headers: {
                        "Content-type": "application/json"
                    },
                    body: JSON.stringify({
                        id: id,
                        type: "size",
                        value: size,
                        color: color
                    })
                });
                const data = await res.json();
                if (!data.success) return;
                
                discount.innerHTML = `₹${data.product.sizes[0].discount}`;
                price.innerHTML = `₹${data.product.sizes[0].price}`;
                updateStockDisplay(data.product.sizes[0].stock || 0);
                quantityInput.value = 1;
            } catch (e) {
                console.error(e);
            }
        });

        

        menuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Initialize stock display and buttons
        updateStockDisplay(currentStock);
    </script>
</body>
</html>