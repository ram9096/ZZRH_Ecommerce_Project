<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#ZZRH Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
        body { font-family: 'DM Sans', sans-serif; }
        .chart-filter-btn {
            transition: all 0.2s ease;
        }
        .chart-filter-btn.active {
            background-color: #111827;
            color: white;
        }
        .chart-filter-btn:not(.active):hover {
            background-color: #f3f4f6;
        }
        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.9);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }
        .hover-lift {
            transition: all 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="bg-white font-sans">

    <!-- Header -->
    <nav class="glass-effect border-b border-white/20 shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <div class="w-10 h-10 gradient-bg rounded-xl flex items-center justify-center text-white font-bold">
                        R
                    </div>
                    <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-800 to-black bg-clip-text text-transparent">#Raftaara</h1>
                </div>
                <button class="relative p-3 hover:bg-white/50 rounded-xl transition-all">
                    <i class="far fa-bell text-xl text-gray-700"></i>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
            </div>
        </div>
    </nav>

    <div class="flex">
        <!-- Main Content -->
        <%- include('../Partials/sidebar') %>
        <main class="flex-1 p-8">
            <h1 class="text-3xl font-bold mb-8">Dashboard</h1>
            
            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="text-sm font-medium text-gray-500 mb-2">Total Orders</h3>
                    <p class="text-2xl font-bold mb-1">1,240</p>
                    <p class="text-green-500 text-sm">+10%</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="text-sm font-medium text-gray-500 mb-2">Customers</h3>
                    <p class="text-2xl font-bold mb-1">680</p>
                    <p class="text-green-500 text-sm">+5%</p>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="text-sm font-medium text-gray-500 mb-2">Revenue</h3>
                    <p class="text-2xl font-bold mb-1">$45,300</p>
                    <p class="text-green-500 text-sm">+8%</p>
                </div>
            </div>

            <!-- Line Chart -->
            <div class="bg-white rounded-xl border border-gray-200 mb-8">
                <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between flex-wrap gap-3">
                    <div>
                        <h2 class="text-xl font-bold">Revenue Overview</h2>
                        <p class="text-sm text-gray-400 mt-0.5">Track revenue, orders, and customers over time</p>
                    </div>
                    <!-- Metric Toggle -->
                    <div class="flex items-center gap-2">
                        <div class="flex rounded-lg border border-gray-200 p-1 gap-1">
                            <button onclick="setMetric('revenue')" id="metric-revenue" class="chart-filter-btn active text-xs font-medium px-3 py-1.5 rounded-md">Revenue</button>
                            <button onclick="setMetric('orders')" id="metric-orders" class="chart-filter-btn text-xs font-medium px-3 py-1.5 rounded-md text-gray-500">Orders</button>
                            <button onclick="setMetric('customers')" id="metric-customers" class="chart-filter-btn text-xs font-medium px-3 py-1.5 rounded-md text-gray-500">Customers</button>
                        </div>
                        <!-- Time Filter -->
                        <div class="flex rounded-lg border border-gray-200 p-1 gap-1">
                            <button onclick="setRange('7d')" id="range-7d" class="chart-filter-btn text-xs font-medium px-3 py-1.5 rounded-md text-gray-500">7D</button>
                            <button onclick="setRange('30d')" id="range-30d" class="chart-filter-btn active text-xs font-medium px-3 py-1.5 rounded-md">30D</button>
                            <button onclick="setRange('90d')" id="range-90d" class="chart-filter-btn text-xs font-medium px-3 py-1.5 rounded-md text-gray-500">90D</button>
                            <button onclick="setRange('1y')" id="range-1y" class="chart-filter-btn text-xs font-medium px-3 py-1.5 rounded-md text-gray-500">1Y</button>
                        </div>
                    </div>
                </div>
                <div class="p-6">
                    <canvas id="lineChart" height="90"></canvas>
                </div>
            </div>
            
            <!-- Recent Orders -->
            <div class="bg-white rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h2 class="text-xl font-bold">Recent Orders</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Customer Name</th>
                                <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Order ID</th>
                                <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Date</th>
                                <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Amount</th>
                                <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Status</th>
                                <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-6 py-4">Sophia Carter</td>
                                <td class="px-6 py-4 text-gray-500">ORD12345</td>
                                <td class="px-6 py-4 text-gray-500">2024-07-26</td>
                                <td class="px-6 py-4 text-gray-500">$120</td>
                                <td class="px-6 py-4"><span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-sm font-medium">Paid</span></td>
                                <td class="px-6 py-4"><button class="text-purple-600 hover:text-purple-800 font-medium">View</button></td>
                            </tr>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-6 py-4">Liam Harper</td>
                                <td class="px-6 py-4 text-gray-500">ORD67890</td>
                                <td class="px-6 py-4 text-gray-500">2024-07-25</td>
                                <td class="px-6 py-4 text-gray-500">$85</td>
                                <td class="px-6 py-4"><span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-sm font-medium">Pending</span></td>
                                <td class="px-6 py-4"><button class="text-purple-600 hover:text-purple-800 font-medium">View</button></td>
                            </tr>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-6 py-4">Olivia Bennett</td>
                                <td class="px-6 py-4 text-gray-500">ORD11223</td>
                                <td class="px-6 py-4 text-gray-500">2024-07-24</td>
                                <td class="px-6 py-4 text-gray-500">$250</td>
                                <td class="px-6 py-4"><span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-sm font-medium">Shipped</span></td>
                                <td class="px-6 py-4"><button class="text-purple-600 hover:text-purple-800 font-medium">View</button></td>
                            </tr>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-6 py-4">Noah Foster</td>
                                <td class="px-6 py-4 text-gray-500">ORD44556</td>
                                <td class="px-6 py-4 text-gray-500">2024-07-23</td>
                                <td class="px-6 py-4 text-gray-500">$150</td>
                                <td class="px-6 py-4"><span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-sm font-medium">Paid</span></td>
                                <td class="px-6 py-4"><button class="text-purple-600 hover:text-purple-800 font-medium">View</button></td>
                            </tr>
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4">Ava Mitchell</td>
                                <td class="px-6 py-4 text-gray-500">ORD77889</td>
                                <td class="px-6 py-4 text-gray-500">2024-07-22</td>
                                <td class="px-6 py-4 text-gray-500">$95</td>
                                <td class="px-6 py-4"><span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-sm font-medium">Shipped</span></td>
                                <td class="px-6 py-4"><button class="text-purple-600 hover:text-purple-800 font-medium">View</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        // --- Data ---
        const data = {
            revenue: {
                '7d':  { labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], values: [1200,980,1450,1100,1700,2100,1850] },
                '30d': { labels: ['Jul 1','Jul 5','Jul 10','Jul 15','Jul 20','Jul 25','Jul 30'], values: [3200,4100,3800,5200,4700,6100,5800] },
                '90d': { labels: ['May','Jun','Jul'], values: [32000, 41000, 45300] },
                '1y':  { labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], values: [21000,24000,19000,27000,30000,32000,45300,41000,38000,43000,47000,52000] },
            },
            orders: {
                '7d':  { labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], values: [42,35,61,48,73,89,77] },
                '30d': { labels: ['Jul 1','Jul 5','Jul 10','Jul 15','Jul 20','Jul 25','Jul 30'], values: [110,145,130,180,165,210,200] },
                '90d': { labels: ['May','Jun','Jul'], values: [980, 1120, 1240] },
                '1y':  { labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], values: [720,810,690,940,1050,1100,1240,1180,1090,1310,1420,1560] },
            },
            customers: {
                '7d':  { labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], values: [18,12,24,19,31,42,38] },
                '30d': { labels: ['Jul 1','Jul 5','Jul 10','Jul 15','Jul 20','Jul 25','Jul 30'], values: [55,72,65,90,82,105,98] },
                '90d': { labels: ['May','Jun','Jul'], values: [480, 580, 680] },
                '1y':  { labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], values: [320,370,310,420,480,530,680,640,590,710,760,840] },
            }
        };

        const metaConfig = {
            revenue:   { label: 'Revenue ($)', color: '#111827', prefix: '$' },
            orders:    { label: 'Orders',      color: '#6366f1', prefix: ''  },
            customers: { label: 'Customers',   color: '#10b981', prefix: ''  },
        };

        let currentMetric = 'revenue';
        let currentRange  = '30d';

        // --- Chart ---
        const ctx = document.getElementById('lineChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'line',
            data: { labels: [], datasets: [{ data: [], fill: true, tension: 0.4, pointRadius: 4, pointHoverRadius: 6, borderWidth: 2 }] },
            options: {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#111827',
                        titleColor: '#9ca3af',
                        bodyColor: '#fff',
                        padding: 12,
                        cornerRadius: 8,
                        callbacks: {
                            label: ctx => {
                                const prefix = metaConfig[currentMetric].prefix;
                                return `  ${prefix}${ctx.parsed.y.toLocaleString()}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#9ca3af', font: { size: 12, family: 'DM Sans' } },
                        border: { display: false }
                    },
                    y: {
                        grid: { color: '#f3f4f6' },
                        ticks: {
                            color: '#9ca3af',
                            font: { size: 12, family: 'DM Sans' },
                            callback: val => metaConfig[currentMetric].prefix + (val >= 1000 ? (val/1000).toFixed(0)+'k' : val)
                        },
                        border: { display: false }
                    }
                }
            }
        });

        function updateChart() {
            const { labels, values } = data[currentMetric][currentRange];
            const { label, color } = metaConfig[currentMetric];

            chart.data.labels = labels;
            chart.data.datasets[0].data = values;
            chart.data.datasets[0].label = label;
            chart.data.datasets[0].borderColor = color;
            chart.data.datasets[0].pointBackgroundColor = color;
            chart.data.datasets[0].backgroundColor = hexToRgba(color, 0.07);

            // update y-axis formatter
            chart.options.scales.y.ticks.callback = val =>
                metaConfig[currentMetric].prefix + (val >= 1000 ? (val/1000).toFixed(0)+'k' : val);

            chart.update('active');
        }

        function hexToRgba(hex, alpha) {
            const r = parseInt(hex.slice(1,3),16);
            const g = parseInt(hex.slice(3,5),16);
            const b = parseInt(hex.slice(5,7),16);
            return `rgba(${r},${g},${b},${alpha})`;
        }

        function setMetric(metric) {
            currentMetric = metric;
            document.querySelectorAll('[id^="metric-"]').forEach(btn => {
                btn.classList.toggle('active', btn.id === `metric-${metric}`);
                if (btn.id !== `metric-${metric}`) btn.classList.add('text-gray-500');
                else btn.classList.remove('text-gray-500');
            });
            updateChart();
        }

        function setRange(range) {
            currentRange = range;
            document.querySelectorAll('[id^="range-"]').forEach(btn => {
                btn.classList.toggle('active', btn.id === `range-${range}`);
                if (btn.id !== `range-${range}`) btn.classList.add('text-gray-500');
                else btn.classList.remove('text-gray-500');
            });
            updateChart();
        }

        // Init
        updateChart();
    </script>
</body>
</html>