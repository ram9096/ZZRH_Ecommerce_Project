<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coupon Management - Raftaara</title>
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.9);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }
        .hover-lift {
            transition: all 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Top Navigation -->
    <nav class="glass-effect border-b border-white/20 shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <div class="w-10 h-10 gradient-bg rounded-xl flex items-center justify-center text-white font-bold">
                        Z
                    </div>
                    <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-800 to-black bg-clip-text text-transparent">#ZZRH</h1>
                </div>
                <button class="relative p-3 hover:bg-white/50 rounded-xl transition-all">
                    <i class="far fa-bell text-xl text-gray-700"></i>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
            </div>
        </div>
    </nav>

    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('../Partials/sidebar') %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <!-- Header Section -->
            <div class="mb-8">
                <div class="flex items-center justify-between mb-2">
                    <div>
                        <h2 class="text-4xl font-bold text-gray-800 mb-1">Coupon Management</h2>
                        <p class="text-gray-500">Organize and manage your coupons</p>
                    </div>
                    <a href="/admin/coupons-add">
                        <button class="px-6 py-3 gradient-bg text-white rounded-xl hover-lift font-medium shadow-lg flex items-center space-x-2">
                            <i class="fas fa-plus-circle"></i>
                            <span>Create coupon</span>
                        </button>
                    </a>
                </div>
            </div>

            <!-- Filters Card -->
            <div class="glass-effect rounded-2xl shadow-xl p-6 mb-6 border border-white/20">
                <div class="flex flex-wrap gap-4 items-center">
                    <!-- Search -->
                    <div class="flex-1 min-w-[300px]">
                        <div class="relative">
                            <i class="fas fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                            <input 
                                type="text" 
                                placeholder="Search coupon..." 
                                value="<%= search ?search:'' %>"
                                onkeyup="handleSearch(this.value)"
                                class="w-full pl-12 pr-4 py-3 bg-white/70 border-2 border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-400 focus:border-transparent transition-all"
                            >
                        </div>
                    </div>

                    <!-- Filters -->
                    <form  class="flex gap-3">
                        <select name="status" onchange="handleStatus(this.value)"  class="px-5 py-3 bg-white/70 border-2 border-gray-300 rounded-xl font-medium hover:bg-white transition-all focus:outline-none focus:ring-2 focus:ring-gray-400 cursor-pointer">
                            <option value=""<%= status=='' ? 'selected':'' %> >📊 All Status</option>
                            <option value="true"<%= status=="true" ? 'selected':'' %> >✅ Active</option>
                            <option value="false" <%= status=="false" ? 'selected':'' %>>❌ Inactive</option>
                        </select>
                        
                        
                    </form>

                    <a href="/admin/coupons">
                        <button class="px-5 py-3 bg-white/70 border-2 border-gray-300 rounded-xl font-medium hover:bg-white transition-all flex items-center space-x-2">
                            <i class="fas fa-redo-alt text-gray-700"></i>
                            <span>Reset</span>
                        </button>
                    </a>
                </div>
            </div>

            

            <!-- Table Card -->
            <div class="glass-effect rounded-2xl shadow-xl overflow-hidden border border-white/20">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="bg-gradient-to-r from-gray-800 to-black text-white">
                                <th class="px-6 py-4 text-left text-sm font-semibold">
                                    <div class="flex items-center space-x-2">
                                        <i class="fas fa-tag"></i>
                                        <span>Coupon Code</span>
                                    </div>
                                </th>
                                <th class="px-6 py-4 text-left text-sm font-semibold">
                                    <div class="flex items-center space-x-2">
                                        <i class="fas fa-align-left"></i>
                                        <span>Discount type</span>
                                    </div>
                                </th>
                                <th class="px-6 py-4 text-left text-sm font-semibold">
                                    <div class="flex items-center space-x-2">
                                        <i class="fas fa-toggle-on"></i>
                                        <span>Discount Value</span>
                                    </div>
                                </th>
                                
                                <th class="px-6 py-4 text-left text-sm font-semibold">
                                    <div class="flex items-center space-x-2">
                                        <i class="fas fa-box"></i>
                                        <span>validity</span>
                                    </div>
                                </th>
                                <th class="px-6 py-4 text-left text-sm font-semibold">
                                    <div class="flex items-center space-x-2">
                                        <i class="fas fa-cog"></i>
                                        <span>Actions</span>
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            
                                <% data.forEach((u,i)=>{ %>
                                    <tr class="hover:bg-gray-100 transition-all">
                                        <td class="px-6 py-5">
                                            <div class="flex items-center space-x-3">
                                                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gray-700 to-black flex items-center justify-center text-white font-bold">
                                                    #<%= i+1 %>
                                                </div>
                                                <span class="font-semibold text-gray-800"><%= u.code %></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 text-gray-600 max-w-xs">
                                            <p class="truncate"><%= u.discountType %></p>
                                        </td>

                                        
                                        <td class="px-6 py-5">
                                            <div class="flex items-center space-x-2">
                                                <div class="w-17 h-10 rounded-lg bg-gray-100 flex items-center justify-center">
                                                    <span class="text-gray-800 font-bold text-sm"><%= u.discountValue %><%= u.discountType == "PERCENTAGE" ? "% OFF":"FLAT OFF" %></span>
                                                </div>
                                            </div>
                                        </td>
                                        
                                        <td class="px-6 py-5">
                                            <div class="flex items-center space-x-2">
                                                <div class="w-28 h-8 rounded-lg bg-gray-100 flex items-center justify-center">
                                                    <span class="text-gray-800 font-bold text-sm"><%= new Date(u.expiryDate).toDateString() %></span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <a href="/admin/coupon-edit/<%= u._id %>">
                                                <button class="px-4 py-2 bg-gradient-to-r from-gray-700 to-black text-white rounded-lg hover-lift font-medium text-sm flex items-center space-x-2">
                                                    <i class="fas fa-edit"></i>
                                                    <span>Edit</span>
                                                </button>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                           
                        </tbody>
                    </table>
                </div>

                
                
            </div>
            <!-- Pagination -->
            <%
                const currentPage = pagination.currentPage;
                const totalOrders = pagination.total;
                const pageLimit = 3; // MUST match backend limit
    
                const start = totalOrders === 0 ? 0 : (currentPage - 1) * pageLimit + 1;
                const end = Math.min(start + totalOrders.length - 1, totalOrders);
            %>
    
            <div class="mt-6 flex items-center justify-between">
    
                <!-- Showing text -->
                <p class="text-gray-600">
                    Showing
                    <span class="font-semibold"><%= start %></span>
                    of
                    <span class="font-semibold"><%= totalOrders %></span>
                    orders
                </p>
    
                <!-- Pagination buttons -->
                <div class="flex gap-2">
    
                    <!-- Prev -->
                    <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>"
                        class="w-10 h-10 border rounded-lg flex items-center justify-center hover:bg-gray-100">
                        ‹
                    </a>
                    <% } else { %>
                    <span class="w-10 h-10 border rounded-lg flex items-center justify-center opacity-40">
                        ‹
                    </span>
                    <% } %>
    
                    <!-- Current -->
                    <span class="w-10 h-10 bg-gray-900 text-white rounded-lg flex items-center justify-center font-semibold">
                    <%= currentPage %>
                    </span>
    
                    <!-- Next -->
                    <% if (currentPage < pagination.totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>"
                        class="w-10 h-10 border rounded-lg flex items-center justify-center hover:bg-gray-100">
                        ›
                    </a>
                    <% } else { %>
                    <span class="w-10 h-10 border rounded-lg flex items-center justify-center opacity-40">
                        ›
                    </span>
                    <% } %>
    
                </div>
            </div>
        </main>
    </div>

    <script>
        let timer;
        function handleSearch(value) {
            clearTimeout(timer);
            timer = setTimeout(() => {
                const params = new URLSearchParams(window.location.search);
                params.set("search", value);
                params.set("page", 1);
                window.location.search = params.toString();
            }, 400);
        }

        function handleStatus(value) {
            const params = new URLSearchParams(window.location.search);

            if (value) {
                params.set("status", value);
            } else {
                params.delete("status");
            }

            params.set("page", 1);
            window.location.search = params.toString();
        }

       
    </script>
</body>
</html>