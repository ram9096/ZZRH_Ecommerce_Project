<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report - #ZZRH</title>
    <script src="https://cdn.tailwindcss.com"></script>
     <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <style>
        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.95);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1f2937 0%, #000000 100%);
        }
        .hover-lift {
            transition: all 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background: white;
            }
            .print-break {
                page-break-after: always;
            }
        }
        .custom-date-inputs {
            display: none;
        }
        .custom-date-inputs.active {
            display: grid;
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Top Navigation Bar -->
    <nav class="glass-effect border-b border-white/20 shadow-lg sticky top-0 z-50 no-print">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <div class="w-10 h-10 gradient-bg rounded-xl flex items-center justify-center text-white font-bold">
                        Z
                    </div>
                    <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-800 to-black bg-clip-text text-transparent">#ZZRH</h1>
                </div>
                <button class="relative p-3 hover:bg-white/50 rounded-xl transition-all">
                    <i class="far fa-bell text-xl text-gray-700"></i>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
            </div>
        </div>
    </nav>

    <div class="flex">
        <!-- Sidebar -->
        <%- include('../Partials/sidebar') %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <!-- Header with Action Buttons -->
            <div class="mb-8 flex justify-between items-start flex-wrap gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-gray-800">Sales Report</h1>
                    <p class="text-gray-600 mt-1">Generate comprehensive sales reports with detailed analytics</p>
                </div>
                <div class="flex space-x-3 no-print">
                    <button onclick="downloadExcel()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition flex items-center space-x-2 shadow-md hover:shadow-lg">
                        <i class="fa-solid fa-file-excel"></i>
                        <span>Export Excel</span>
                    </button>
                    <button onclick="downloadPDF()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition flex items-center space-x-2 shadow-md hover:shadow-lg">
                        <i class="fa-solid fa-file-pdf"></i>
                        <span>Export PDF</span>
                    </button>
                    <button onclick="window.print()" class="px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-800 transition flex items-center space-x-2 shadow-md hover:shadow-lg">
                        <i class="fa-solid fa-print"></i>
                        <span>Print</span>
                    </button>
                </div>
            </div>

           

            <!-- Report Content -->
            <div id="reportContent">
               

                <!-- Key Summary Statistics -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                    <!-- Overall Sales Count -->
                    <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-6 rounded-xl shadow-lg text-white">
                        <div class="flex items-center justify-between mb-4">
                            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-shopping-cart text-2xl"></i>
                            </div>
                            <i class="fa-solid fa-arrow-trend-up text-2xl opacity-50"></i>
                        </div>
                        <h3 class="text-sm font-medium mb-1 opacity-90">Overall Sales Count</h3>
                        <p class="text-3xl font-bold" id="overallSalesCount"><%= totalOrders %></p>
                        <p class="text-xs mt-2 opacity-75">Total orders in period</p>
                    </div>

                    <!-- Overall Order Amount -->
                    <div class="bg-gradient-to-br from-green-500 to-green-600 p-6 rounded-xl shadow-lg text-white">
                        <div class="flex items-center justify-between mb-4">
                            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-indian-rupee-sign text-2xl"></i>
                            </div>
                            <i class="fa-solid fa-chart-line text-2xl opacity-50"></i>
                        </div>
                        <h3 class="text-sm font-medium mb-1 opacity-90">Overall Order Amount</h3>
                        <p class="text-3xl font-bold" id="overallOrderAmount">₹<%= fullRevenue.toLocaleString('en-IN') %></p>
                        <p class="text-xs mt-2 opacity-75">Gross sales revenue</p>
                    </div>

                    <!-- Overall Discount -->
                    <div class="bg-gradient-to-br from-orange-500 to-orange-600 p-6 rounded-xl shadow-lg text-white">
                        <div class="flex items-center justify-between mb-4">
                            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-tags text-2xl"></i>
                            </div>
                            <i class="fa-solid fa-percent text-2xl opacity-50"></i>
                        </div>
                        <h3 class="text-sm font-medium mb-1 opacity-90">Overall Discount</h3>
                        <p class="text-3xl font-bold" id="overallDiscount">₹<%= fullDiscount %></p>
                        <p class="text-xs mt-2 opacity-75">Total discounts applied</p>
                    </div>

                    <!-- Net Revenue -->
                    <div class="bg-gradient-to-br from-purple-500 to-purple-600 p-6 rounded-xl shadow-lg text-white">
                        <div class="flex items-center justify-between mb-4">
                            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-wallet text-2xl"></i>
                            </div>
                            <i class="fa-solid fa-sack-dollar text-2xl opacity-50"></i>
                        </div>
                        <h3 class="text-sm font-medium mb-1 opacity-90">Net Revenue</h3>
                        <p class="text-3xl font-bold" id="netRevenue">₹<%= fullRevenue - fullDiscount %></p>
                        <p class="text-xs mt-2 opacity-75">After discounts </p>
                    </div>
                </div>

                 <!-- Report Filters -->
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6 no-print">
                    <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
                        <i class="fa-solid fa-filter mr-2 text-red-600"></i>
                        Report Filters
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-regular fa-calendar mr-1"></i>Time Period
                            </label>
                            <select id="dateRange" name="period" onchange="toggleCustomDate()"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg">
                                <option value="all" <%= period === "all" ? "selected" : "" %>>All</option>
                                <option value="month" <%= period === "month" ? "selected" : "" %>>This Month</option>
                                <option value="today" <%= period === "today" ? "selected" : "" %>>Today</option>
                                <option value="yesterday" <%= period === "yesterday" ? "selected" : "" %>>Yesterday</option>
                                <option value="week" <%= period === "week" ? "selected" : "" %>>This Week</option>
                                
                                
                                <option value="year" <%= period === "year" ? "selected" : "" %>>This Year</option>
                                <option value="custom" <%= period === "custom" ? "selected" : "" %>>Custom Date Range</option>

                            </select>

                        </div>
                        
                        
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-solid fa-circle-check mr-1"></i>Order Status
                            </label>
                            <select id="statusFilter" name="status"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg">

                                <option value="all" <%= status === "all" ? "selected" : "" %>>All Orders</option>
                                <option value="completed" <%= status === "completed" ? "selected" : "" %>>Completed</option>
                                <option value="placed" <%= status === "placed" ? "selected" : "" %>>Pending</option>
                                <option value="cancelled" <%= status === "cancelled" ? "selected" : "" %>>Cancelled</option>

                            </select>

                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-solid fa-credit-card mr-1"></i>Payment Method
                            </label>
                            <select id="paymentFilter" name="payment"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg">

                                <option value="all" <%= payment === "all" ? "selected" : "" %>>All Methods</option>
                                <option value="WALLET" <%= payment === "WALLET" ? "selected" : "" %>>WALLET</option>
                                <option value="PAYPAL" <%= payment === "PAYPAL" ? "selected" : "" %>>PAYPAL</option>
                                <option value="COD" <%= payment === "COD" ? "selected" : "" %>>Cash on Delivery</option>

                            </select>

                        </div>
                    </div>

                    <!-- Custom Date Range Inputs -->
                    <div id="customDateInputs" class="custom-date-inputs grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-regular fa-calendar-days mr-1"></i>Start Date
                            </label>
                            <input type="date" id="startDate" value="<%= start ? new Date(start).toISOString().split('T')[0] : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-regular fa-calendar-days mr-1"></i>End Date
                            </label>
                            <input type="date" id="endDate" value="<%= end ? new Date(end).toISOString().split('T')[0] : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                        </div>
                    </div>

                    <div class="flex justify-between items-center pt-4 border-t border-gray-200">
                        <a href="/admin/analytics">
                            <button  class="px-4 py-2 text-gray-600 hover:text-gray-800 transition">
                                <i class="fa-solid fa-rotate-left mr-2"></i>Reset Filters
                            </button>
                        </a>
                        <button id="generate-btn" class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition shadow-md hover:shadow-lg">
                            <i class="fa-solid fa-chart-bar mr-2"></i>Generate Report
                        </button>
                    </div>
                </div>
                <% 
                   let total = 0
                   let deduction = 0
                   coupon.forEach(c=>{
                    if(c.baseLimit&&c.usageLimit<c.baseLimit){
                        total += (c.baseLimit-c.usageLimit)*c.discountValue
                        deduction += (c.baseLimit-c.usageLimit)
                    }
                   })
                 %>
                <!-- Discount & Coupon Breakdown -->
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6">
                    <h2 class="text-lg font-semibold text-gray-800 mb-6 flex items-center">
                        <i class="fa-solid fa-ticket mr-2 text-orange-600"></i>
                        Discount & Coupon Deductions
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-orange-50 p-4 rounded-lg border border-orange-200">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-sm font-medium text-gray-700">Product Discounts</span>
                                <i class="fa-solid fa-tag text-orange-600"></i>
                            </div>
                            <p class="text-2xl font-bold text-gray-800" id="productDiscounts">₹<%= total %></p>
                            <p class="text-xs text-gray-600 mt-1">Item-level discounts</p>
                        </div>
                        
                        
                        
                        <div class="bg-red-50 p-4 rounded-lg border border-red-200">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-sm font-medium text-gray-700">Total Deductions</span>
                                <i class="fa-solid fa-calculator text-red-600"></i>
                            </div>
                            <p class="text-2xl font-bold text-gray-800" id="totalDeductions"><%= deduction %></p>
                            <p class="text-xs text-gray-600 mt-1">All discounts combined</p>
                        </div>
                    </div>

                    

                    <!-- Coupon Usage Details -->
                    <div class="mt-6">
                        <h3 class="text-md font-semibold text-gray-800 mb-4">Coupon Code Usage</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Coupon Code</th>
                                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Times Used</th>
                                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Discount Type</th>
                                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Total Discount</th>
                                    </tr>
                                </thead>
                                <% if(coupon.length == 0) {%>
                                    <tbody class="divide-y divide-gray-200" id="couponTableBody">
                                        <tr>
                                            <td colspan="4" class="px-4 py-8 text-center text-gray-500">
                                                <i class="fa-solid fa-ticket text-3xl mb-2 opacity-30"></i>
                                                <p>No coupon usage in selected period</p>
                                            </td>
                                        </tr>
                                    </tbody>
                                <% }else{ %>
                                    <tbody class="divide-y divide-gray-200" >
                                        <% coupon.forEach(c=>{ %>
                                            <% if(c.baseLimit&&c.usageLimit<c.baseLimit) {%>
                                                <tr>
                                                    <td class="px-4 py-3 text-left text-s font-medium text-gray-800 uppercase"><%= c.code %></td>
                                                    <td class="px-4 py-3 text-left text-s font-medium text-gray-800 uppercase"><%= c.baseLimit-c.usageLimit %></td>
                                                    <td class="px-4 py-3 text-left text-s font-medium text-gray-800 uppercase"><%= c.discountType %></td>
                                                    <td class="px-4 py-3 text-left text-s font-medium text-gray-800 uppercase"><%= (c.baseLimit-c.usageLimit)*c.discountValue %></td>
                                                </tr>
                                            <% } %>
                                        <% }) %>
                                    </tbody>
                                <% } %>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Product Sales Breakdown -->
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6">
                    <h2 class="text-lg font-semibold text-gray-800 mb-6 flex items-center">
                        <i class="fa-solid fa-box-open mr-2 text-blue-600"></i>
                        Product Sales Breakdown
                    </h2>
                    <div class="overflow-x-auto">
                        <table class="w-full" id="productSalesTable">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Product Name</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Units Sold</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Gross Amount</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Discount</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Net Revenue</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Return orders</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase">Cancelled</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                <%
                                    function getUnitsSoldByItemName(itemName) {
                                        let totalUnits = 0;
                                        let totalRevenue = 0;
                                        let totalDiscount = 0;
                                        let totalReturn  = 0
                                        let totalCancelled = 0
                                        let statusv = status!="all" ? status.toUpperCase():'COMPLETED' 
                                        order.forEach(orders => {
                                            orders.orderItems.forEach(item => {

                                                if(orders.orderStatus.toUpperCase()==statusv){
                                                    
                                                    if (item.productName === itemName) {
                                                        if(orders.cancelledAt){
                                                            orders.cancelledAt.forEach((e=>{
                                                                e.cancelledProducts.forEach(u=>{
                                                                    
                                                                    if(u==item.variantId._id){
                                                                        totalCancelled+=item.quantity
                                                                    }
                                                                })
                                                            }))
                                                        }

                                                        if(orders.returnedAt){
                                                            totalReturn+=item.quantity
                                                        }else{

                                                            totalUnits += item.quantity;
                                                            totalRevenue += item.quantity * item.price;
                                                            if(item.variantId.basePrice != null&&item.variantId.basePrice!=item.variantId.price){
                                                                
                                                                totalDiscount += (item.variantId.basePrice - item.variantId.price)*item.quantity
                                                                
                                                            }
                                                        }
                                                        
                                                    }
                                                }
                                            });
                                        });
                                        order.forEach(orders => {
                                            orders.orderItems.forEach(item => {
                                                if (item.productName === itemName) {
                                                    
                                                    if(orders.cancelledAt){
                                                        orders.cancelledAt.forEach((e=>{
                                                            e.cancelledProducts.forEach(u=>{
                                                                if(u._id.toString()==item.variantId._id.toString()){
                                                                    totalCancelled+=item.quantity
                                                                }
                                                            })
                                                        }))
                                                    }
                                                    
                                                }
                                                
                                            });
                                        });
                                        
                                        return {
                                            totalUnits,
                                            totalRevenue,
                                            totalDiscount,
                                            totalReturn,
                                            netRevenue: totalRevenue,
                                            totalCancelled
                                        };
                                    } 
                                    
                                    let grandTotalUnits = 0;
                                    let grandTotalRevenue = 0;
                                    let grandTotalDiscount = 0;
                                    let grandTotalReturn = 0
                                    let grandTotalCancel = 0
                                %>
                                <% product.forEach(item => { %>
                                    <% const { totalUnits, totalRevenue, totalDiscount,totalReturn, netRevenue,totalCancelled } = getUnitsSoldByItemName(item.name) %>
                                    <% if(totalUnits>=0) {%>
                                        <% grandTotalUnits += totalUnits; %>
                                        <% grandTotalRevenue += totalRevenue; %>
                                        <% grandTotalDiscount += totalDiscount; %>
                                        <% grandTotalReturn+=totalReturn %>
                                        <% grandTotalCancel+=totalCancelled %>
                                        <tr class="hover:bg-gray-50">
                                            <td class="px-4 py-4">
                                                <div class="flex items-center space-x-3">
                                                    <div class="w-10 h-10 bg-gray-200 rounded-lg flex items-center justify-center">
                                                        <i class="fa-solid fa-box text-gray-500"></i>
                                                    </div>
                                                    <span class="font-medium text-gray-800"><%= item.name %></span>
                                                </div>
                                            </td>
                                            <td class="px-4 py-4 text-gray-600"><%= totalUnits %></td>
                                            <td class="px-4 py-4 text-gray-800 font-medium">₹<%= totalRevenue.toLocaleString('en-IN') %></td>
                                            <td class="px-4 py-4 text-orange-600">-₹<%= totalDiscount.toLocaleString('en-IN') %></td>
                                            <td class="px-4 py-4 text-green-600 font-semibold">₹<%= netRevenue.toLocaleString('en-IN') %></td>
                                            <td class="px-4 py-4 text-red-600 font-semibold"><%= totalReturn%></td>
                                            <td class="px-4 py-4 text-red-600 font-semibold"><%= totalCancelled %></td>
                                            
                                        </tr>
                                    <% } %>
                                <% }) %>
                                <tr class="bg-gray-100 font-semibold border-t-2 border-gray-300">
                                    <td class="px-4 py-4 text-gray-800">TOTAL</td>
                                    <td class="px-4 py-4 text-gray-800"><%= grandTotalUnits %></td>
                                    <td class="px-4 py-4 text-gray-800">₹<%= grandTotalRevenue.toLocaleString('en-IN') %></td>
                                    <td class="px-4 py-4 text-orange-600">-₹<%= grandTotalDiscount.toLocaleString('en-IN') %></td>
                                    <td class="px-4 py-4 text-green-600">&#8377;<%= (grandTotalRevenue - grandTotalDiscount).toLocaleString('en-IN') %></td>
                                    <td class="px-4 py-4 text-red-600"><%= grandTotalReturn%></td>
                                    <td class="px-4 py-4 text-red-600"><%= grandTotalCancel%></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <%
                        function getPercentage(){
                            let COD = 0
                            let PAYPAL = 0
                            let WALLET = 0
                            let completed = 0
                            let placed = 0
                            let cancelled = 0
                            order.forEach(o=>{
                            
                                if(o.orderStatus.toUpperCase() == "COMPLETED"){
                                    completed += 1
                                    if(o.orderMethod == "COD"){
                                        if(!o.returnedAt){

                                            COD+=o.totalAmount
                                        }
                                        
                                    }else if(o.orderMethod == "PAYPAL"){
                                        if(!o.returnedAt){
                                            
                                            PAYPAL+=o.totalAmount
                                        }
                                    }else{
                                        if(!o.returnedAt){

                                            WALLET+=o.totalAmount
                                        }
                                        
                                        
                                    }
                                }else if(o.orderStatus.toUpperCase() == "PLACED"){
                                    placed+=1
                                }else{
                                    cancelled+=1
                                }
                            })

                            return {
                                cod:COD,
                                paypal:PAYPAL,
                                wallet:WALLET,
                                completed,
                                placed,
                                cancelled
                            }
                        } 
                    %>
                    <% const {cod,paypal,wallet,completed,placed,cancelled } = getPercentage() %>

                <!-- Additional Analytics -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
                    <!-- Order Status Distribution -->
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-800 mb-6 flex items-center">
                            <i class="fa-solid fa-chart-pie mr-2 text-purple-600"></i>
                            Order Status Distribution
                        </h2>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <div class="w-4 h-4 bg-green-500 rounded-full"></div>
                                    <span class="text-gray-700 font-medium">Completed</span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-gray-800"><%= grandTotalUnits %></span>
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <div class="w-4 h-4 bg-blue-500 rounded-full"></div>
                                    <span class="text-gray-700 font-medium">Processing</span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-gray-800"><%= placed %></span>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between p-3 bg-red-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <div class="w-4 h-4 bg-red-500 rounded-full"></div>
                                    <span class="text-gray-700 font-medium">Cancelled</span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-gray-800"><%= grandTotalCancel %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Payment Methods Distribution -->
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-800 mb-6 flex items-center">
                            <i class="fa-solid fa-credit-card mr-2 text-green-600"></i>
                            Payment Methods Distribution
                        </h2>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <i class="fa-solid fa-credit-card text-blue-600 text-lg"></i>
                                    <span class="text-gray-700 font-medium">WALLET</span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-gray-800">₹<%= wallet.toFixed(2) %></span>
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-3 bg-purple-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <i class="fa-brands fa-paypal text-blue-600 text-lg"></i>
                                    <span class="text-gray-700 font-medium">PAYPAL</span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-gray-800">₹<%= paypal.toFixed(2) %></span>
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <i class="fa-solid fa-money-bill-wave text-green-600 text-lg"></i>
                                    <span class="text-gray-700 font-medium">Cash on Delivery</span>
                                </div>
                                <div class="text-right">
                                    <span class="font-bold text-gray-800">₹<%= cod.toFixed(2) %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Report Footer -->
                <div class="bg-gradient-to-r from-gray-50 to-gray-100 p-6 rounded-xl border border-gray-200">
                    <div class="text-center">
                        <p class="text-sm text-gray-600 mb-2">
                            <i class="fa-solid fa-lock mr-1"></i>
                            This report contains confidential business information. Handle with care.
                        </p>
                        <p class="text-xs text-gray-500">
                            © <%= new Date().getFullYear() %> #ZZRH. All rights reserved. | Generated by Sales Analytics System
                        </p>
                        <p class="text-xs text-gray-500 mt-1">
                            Report ID: <span class="font-mono">SR-<%= Date.now() %></span>
                        </p>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script>
        // Initialize dates
        const todayDate = new Date().toISOString().split("T")[0];
        const startInput = document.getElementById("startDate");
        const endInput = document.getElementById("endDate");

        startInput.max = todayDate
        endInput.max = todayDate
        startInput.addEventListener('input',(e)=>{
            endInput.min = e.target.value
            if (endInput.value && endInput.value < e.target.value) {
                endInput.value = "";
            }
        })
        async function downloadPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();

            const pageWidth = doc.internal.pageSize.getWidth();

            
            doc.setFont("helvetica", "bold");
            doc.setFontSize(18);
            doc.text("SALES REPORT", 14, 20);

            doc.setFontSize(12);
            doc.setFont("helvetica", "normal");
            doc.text("Raftaara", 14, 28);

            doc.setFontSize(10);
            doc.text("Generated on: " + new Date().toLocaleString(), 14, 35);

            
            const start = document.getElementById("startDate")?.value;
            const end = document.getElementById("endDate")?.value;
            const period = document.getElementById("dateRange")
            if(period == 'custom'){

                if (start && end) {
                    doc.text(`Report Period: ${start} to ${end}`, 14, 42);
                }
            }

            // ===== TABLE =====
            doc.autoTable({
                html: "#productSalesTable",
                startY: 50,
                theme: "grid",
                headStyles: {
                    fillColor: [22, 160, 133], 
                    textColor: 255,
                    fontStyle: "bold"
                },
                styles: {
                    fontSize: 9,
                    cellPadding: 3
                },
                alternateRowStyles: {
                    fillColor: [245, 245, 245]
                }
            });

            // ===== FOOTER =====
            const pageCount = doc.internal.getNumberOfPages();
            for (let i = 1; i <= pageCount; i++) {
                doc.setPage(i);
                doc.setFontSize(9);
                doc.text(
                    `Page ${i} of ${pageCount}`,
                    pageWidth - 30,
                    doc.internal.pageSize.height - 10
                );
            }

            doc.save("Raftaara_Sales_Report.pdf");
        }
        function downloadExcel() {
            const table = document.getElementById("productSalesTable");

            const wb = XLSX.utils.book_new();

            // Convert table to JSON first (clean method)
            const tableData = XLSX.utils.sheet_to_json(
                XLSX.utils.table_to_sheet(table),
                { header: 1 }
            );

            const now = new Date();
            const formattedDate = now.toLocaleString();

            // Create final sheet data
            const finalData = [
                ["SALES REPORT"],
                ["Generated On:", formattedDate],
                [],
                ...tableData
            ];

            const ws = XLSX.utils.aoa_to_sheet(finalData);

            XLSX.utils.book_append_sheet(wb, ws, "Sales Report");

            XLSX.writeFile(wb, "Sales_Report.xlsx");
        }

        const today = new Date();
        document.getElementById('endDate').valueAsDate = today;
        const weekAgo = new Date(today);
        weekAgo.setDate(weekAgo.getDate() - 7);
        document.getElementById('startDate').valueAsDate = weekAgo;

        let generate = document.getElementById('generate-btn')

        generate.addEventListener('click',async()=>{
            let filter = {}
            const period = document.getElementById('dateRange')
            const status = document.getElementById('statusFilter')
            const payment = document.getElementById('paymentFilter')
            const from = document.getElementById('startDate')
            const to = document.getElementById('endDate')
            
             let url = `/admin/analytics?period=${period.value}&status=${status.value}&payment=${payment.value}`;

            if (period.value === "custom") {
                url += `&from=${from.value}&to=${to.value}`;
            }

            // Redirect instead of fetch
            window.location.href = url;
        })

        // Toggle custom date inputs
        function toggleCustomDate() {
            const dateRange = document.getElementById('dateRange').value;
            const customInputs = document.getElementById('customDateInputs');
            
            if (dateRange === 'custom') {
                customInputs.classList.add('active');
            } else {
                customInputs.classList.remove('active');
            }
        }
        toggleCustomDate()
        
        
    </script>
</body>
</html>